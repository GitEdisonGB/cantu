Static Function MENUDEF()
	Local aOpcoes := {}

	AADD(aOpcoes, {"Pesquisar"	, "AxPesqui"   		, 0, 1})
	AADD(aOpcoes, {"Visualizar"	, "U_2RJFINP03"		, 0, 2})
	AADD(aOpcoes, {"Incluir"	, "U_3RJFINP03()"	, 0, 3})
	AADD(aOpcoes, {"Excluir"	, "U_5RJFINP03"  	, 0, 5})

Return aOpcoes


