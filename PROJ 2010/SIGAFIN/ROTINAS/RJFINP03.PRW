User Function RJFINP03()

	Private cCadastro := "Carta Desconto Fornecedor" //Variavel padrуo para o tэtulo do mBrowse
	Private aRotina	:= MENUDEF() //Variсvel padrуo para as opчєes do mBrowse


	dbSelectArea("Z45")
	Z45->(dbsetOrder(1))
	Z45->(dbGoTop())

	//Os parametros sуo padrєes do tamanho da tela que abriu
	mBrowse(6,1,22,75,"Z45")

Return


