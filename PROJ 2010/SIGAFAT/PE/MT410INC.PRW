ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺDesc.     ｳFun鈬o para calculo de desconto de comisss com base sobre ｺｱｱ
ｱｱｺ          ｳas regras de desconto de comisss.                         ｺｱｱ
ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺUso       ｳ RJU                                                        ｺｱｱ
ｱｱﾈﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｼｱｱ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟ
*/ 
	*---------------------------*
User Function RJF410CD()
	*---------------------------*
	Local aArea := GetArea()
	Local lFOUNDR := .F.
	Local cCODREG := ""
	Local cNUMPED := SC5->C5_NUM
	Local cCODVEN := SC5->C5_VEND1
	Local cCODCLI := SC5->C5_CLIENTE
	Local cLOJCLI := SC5->C5_LOJACLI
	Local nPerDesc := 0

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄ
//ｳChama fun鈬o para monitor uso de fontes customizadosｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄ
	U_USORWMAKE(ProcName(),FunName())


	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳ Percorre itens do pedido de venda                         ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	dbSelectArea("SC6")
	dbSetOrder(1)
	If dbSeek ( xFilial("SC6") + cNUMPED )

		While !SC6->(EOF()) .and. SC6->C6_FILIAL == xFilial("SC6") .and. SC6->C6_NUM == cNUMPED

			//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
			//ｳ Verifica se o item possui desconto                        ｳ
			//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
			// C6_PRCTAB - C6_PRCVEN
			//If SC6->C6_DESCONT != 0
			// Flavio - alterado para buscar o desconto de acordo com o campo C6_PRCTAB
			if (SC6->C6_PRCTAB - SC6->C6_PRCVEN) > 0
				nPerDesc := ((SC6->C6_PRCTAB - (SC6->C6_X_VLORI / SC6->C6_QTDVEN)) / SC6->C6_PRCTAB) * 100

				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳ Posiciona sobre o cadastro de produto.                    ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

				dbSelectArea("SB1")
				dbSetOrder(1)
				dbSeek ( xFilial("SB1") + SC6->C6_PRODUTO )

				lFOUNDR := .F.


				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳ Verifica se existe regra de desconto para o vendedor      ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

				dbSelectArea("Z14")	//CABECALHO DESCONTOS COMISSOES
				dbSetOrder(2)	//Z14_FILIAL+Z14_CODVEN
				dbGoTop()
				If dbSeek ( xFilial("Z14") + cCODVEN )
					While !Z14->(EOF()) .and. Z14->Z14_FILIAL == xFilial("Z14") .and. Z14->Z14_CODVEN == cCODVEN
						If Z14->Z14_ATIVO == "S"
							cCODREG := Z14->Z14_CODIGO
							lFOUNDR := .T.
							Exit
						EndIf
						Z14->(dbSkip())
					Enddo
				EndIf


				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳ Verifica se existe regra de desconto para o supervidor do vendedor       ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

				If ! lFOUNDR

					//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
					//ｳ Posiciona sobre o cadastro do vendedor                    ｳ
					//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

					dbSelectArea("SA3")
					dbSetOrder(1)
					dbSeek( xFilial("SA3") + cCODVEN )

					If !Empty(SA3->A3_SUPER)

						dbSelectArea("Z14")	//CABECALHO DESCONTOS COMISSOES
						dbSetOrder(3)	//Z14_FILIAL+Z14_CODSUP
						dbGoTop()
						If dbSeek ( xFilial("Z14") + SA3->A3_SUPER )
							While !Z14->(EOF()) .and. Z14->Z14_FILIAL == xFilial("Z14") .and. Z14->Z14_CODSUP == SA3->A3_SUPER
								If Z14->Z14_ATIVO == "S"
									cCODREG := Z14->Z14_CODIGO
									lFOUNDR := .T.
									Exit
								EndIf
								Z14->(dbSkip())
							Enddo
						EndIf
					EndIf

				EndIf


				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳ Verifica se existe regra de desconto para o gerente do vendedor          ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

				If ! lFOUNDR

					//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
					//ｳ Posiciona sobre o cadastro do vendedor                    ｳ
					//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

					dbSelectArea("SA3")
					dbSetOrder(1)
					dbSeek( xFilial("SA3") + cCODVEN )

					If !Empty(SA3->A3_GEREN)

						dbSelectArea("Z14")	//CABECALHO DESCONTOS COMISSOES
						dbSetOrder(4)	//Z14_FILIAL+Z14_CODGER
						dbGoTop()
						If dbSeek ( xFilial("Z14") + SA3->A3_GEREN )
							While !Z14->(EOF()) .and. Z14->Z14_FILIAL == xFilial("Z14") .and. Z14->Z14_CODGER == SA3->A3_GEREN
								If Z14->Z14_ATIVO == "S"
									cCODREG := Z14->Z14_CODIGO
									lFOUNDR := .T.
									Exit
								EndIf
								Z14->(dbSkip())
							Enddo
						EndIf
					EndIf

				EndIf


				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳ Verifica se encontrou a regra e realiza demais valida鋏es ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

				If lFOUNDR

					dbSelectArea("Z14")	//CABECALHO DESCONTOS COMISSOES
					dbSetOrder(1)	//Z14_FILIAL+Z14_CODIGO
					dbSeek ( xFilial("Z14") + cCODREG )

					//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
					//ｳ Verifica se regra ativa e dentro do intervalo de datas    ｳ
					//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

					If Z14->Z14_ATIVO == "S" .and. SC5->C5_EMISSAO >= Z14->Z14_DATINI .and. SC5->C5_EMISSAO <= Z14->Z14_DATFIN

						//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
						//ｳ Percorre itens da regra para determinar o percentual de desconto com base no desconto do item.   ｳ
						//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

						dbSelectArea("Z15")	//ITENS DESCONTOS COMISSOES
						dbSetOrder(1)	//Z15_FILIAL+Z15_CODIGO+Z15_ITEM
						dbGoTop()
						If dbSeek ( xFilial("Z15") + Z14->Z14_CODIGO )
							While !Z15->(EOF()) .and. Z15->Z15_FILIAL == xFilial("Z15") .and. Z15->Z15_CODIGO == Z14->Z14_CODIGO

								// Flavio - implementado o controle do grupo de produto e do produto, permitindo tamb駑 que se deixado
								// em branco seja considerado para todos
								// Pode-se tamb駑 usar somente os dois primeiros d刕itos do grupo
								if (Empty(Z15->Z15_CODGRP) .AND. Empty(Z15->Z15_CODPRD)) ;
										.OR. (Z15->Z15_CODPRD == SB1->B1_COD);
										.OR. (Z15->Z15_CODGRP == SB1->B1_GRUPO);
										.OR. (TRIM(Z15->Z15_CODGRP) == SUBSTR(SB1->B1_GRUPO, 1, 2))
									// Flavio - alterado para buscar o desconto de acordo com o campo C6_PRCTAB
									// SC6->C6_DESCONT                // SC6->C6_DESCONT
									If nPerDesc >= Z15->Z15_PRCINI .and. nPerDesc <= Z15->Z15_PRCFIN
										If RecLock("SC6", .F.)
											SC6->C6_COMIS1 := SC6->C6_COMIS1 - ( (SC6->C6_COMIS1 * Z15->Z15_PRCDES) / 100 )
											SC6->(MsUnLock())
										EndIf
										// flavio - 06/05/2011
										// se encontra um registro com o desconto cadastrado, pula e nao faz novamente o desconto
										Exit

									EndIf
								EndIf

								Z15->(dbSkip())
							Enddo
						EndIf

					EndIf

				EndIf

			EndIf

			SC6->(dbSkip())

		Enddo

	EndIf

Return

User Function BaseFlex()

	Local aArea := GetArea()
	Local cFil := SC5->C5_FILIAL
	Local cPedido := SC5->C5_NUM
	Local cArmaz := ""
	Local nVlrTab := 0
	Local nDesc := 0
	Local nBaseFlex := 0

	DbSelectArea("SC6")
	DbGoTop()
	DbSeek(cFil + cPedido)

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄ
//ｳChama fun鈬o para monitor uso de fontes customizadosｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄ
	U_USORWMAKE(ProcName(),FunName())

	While !SC6->(EOF()) .and. SC6->C6_FILIAL == cFil .and. SC6->C6_NUM == cPedido
		cArmaz := SC6->C6_LOCAL
		nVlrTab := SC6->C6_PRCTAB

		nDesc := Posicione("SZA", 1, cFil + cArmaz, "ZA_DESCSYN")
		nDesc := nDesc/100

		nBaseFlex := Round(nVlrTab - (nVlrTab * nDesc),2)

		RecLock("SC6", .F.)
		SC6->C6_X_SFLEX := nBaseFlex
		MsUnlock("SC6")

		SC6->(DbSkip())
	End

	RestArea(aArea)

Return



