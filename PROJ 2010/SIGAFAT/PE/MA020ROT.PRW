//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄ
U_USORWMAKE(ProcName(),FunName())

aRetorno := {}
	AAdd( aRetorno, { "Contatos RJU", "U_RJM020CT", 2, 0 } )
	AAdd( aRetorno, { "Log Altera鈬o", "U_RJM020LG", 2, 0 } )
	AAdd( aRetorno, { "Alt. Tp. Fornecedor", "U_CHTPFORN", 2, 0 } ) //Edison G. Barbieri 18/06/2026
	AAdd( aRetorno, { "Agente Comissionado", "U_CADAGFORN", 2, 0 } ) //Edison G. Barbieri 18/06/2026
	
Return( aRetorno )                   
