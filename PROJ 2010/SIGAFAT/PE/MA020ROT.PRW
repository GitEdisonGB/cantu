User Function RJM020CT()
Local aAreaTMP := GetArea()
	U_FCONRJU("SA2",SA2->A2_COD,SA2->A2_LOJA,SA2->A2_NOME)
	RestArea(aAreaTMP)

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄ
