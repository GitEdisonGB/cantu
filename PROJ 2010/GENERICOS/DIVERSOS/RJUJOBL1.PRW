/*{Protheus.doc} FATJOBCP
Funчєes que serс schedulada para faturamento.
@author  Edison G. Babieri
@version P12
@since 	 30/07/2021
@return  Nil
*/

USER FUNCTION FATJOBCP(aParam)

	Local olErro := ErrorBlock({|e| IIF(VALTYPE(e:Description)=="C",CONOUT("### FATJOBCP: ERRO BEGIN SEQUENCE:  "+e:Description),e:Description) })
	Local cNomeSemaf	:= "FATJOBCP"
	Local nHSemafaro

	Private clEmp
	Private clFilial


	Default aParam	:= {"40", "10"}

	clEmp     := aParam[1]
	clFilial  := aParam[2]

	PREPARE ENVIRONMENT EMPRESA clEmp FILIAL clFilial

	/*--------------------------
		ABRE SEMAFORO
	---------------------------*/
	cNomeSemaf	:= cNomeSemaf+clEmp+clFilial
	nHSemafaro	:= U_CPXSEMAF("A", cNomeSemaf)			
	IF nHSemafaro > 0
			
		Begin Sequence
			
			clDateTime	:= DTOS(DDATABASE)+ TIME()
			
			CONOUT("### FATJOBCP: INICIO [" +clDateTime +"] -"+ DTOC(DDATABASE)+ " " + TIME() + " EMPRESA " + clEmp + " FILIAL " + clFilial )
							
			U_RJUJOBL1()
				
			CONOUT("### FATJOBCP: FINAL [" +clDateTime +"] -"+ DTOC(DDATABASE)+ " " + TIME() + " EMPRESA " + clEmp + " FILIAL " + clFilial )
			
		End Sequence

		/*--------------------------
			FECHA SEMAFORO
		---------------------------*/
		U_CPXSEMAF("F", cNomeSemaf, nHSemafaro)			
	ELSE
		CONOUT("### FATJOBCP: NAO FOI POSSIVEL ABRIR O SEMAFORO - ROTINA J┴ ESTA EM EXECUCAO ["+cNomeSemaf+"]" + " EMPRESA " + clEmp + " FILIAL " + clFilial)
	ENDIF
	
	ErrorBlock(olErro)		
	
	RESET ENVIRONMENT

RETURN

/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒╔══════════╤══════════╦═══════╤════════════════════╦══════╤═════════════╗▒▒
▒▒║Programa  │RJUJOBL1    ║Autor  │Rafael Parma      ║ Data │  27/06/12   ║▒▒
▒▒╠══════════╪══════════╩═══════╧════════════════════╩══════╧═════════════╣▒▒
▒▒║Desc.     │Job para processamento de registros da tabela SL1, realiza a║▒▒
▒▒║          │atualizaчуo do campo L1_SITUA para registros com erro 'ER'. ║▒▒
▒▒║          │Executado atravщs do schedule (U_RJUJOBL1(Empresa, Filial)) ║▒▒
▒▒╠══════════╪════════════════════════════════════════════════════════════╣▒▒
▒▒║Uso       │CANTU                                                       ║▒▒
▒▒╚══════════╧════════════════════════════════════════════════════════════╝▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
	*---------------------------------------------------------------------------*
User Function RJUJOBL1(aParam)
	*---------------------------------------------------------------------------*
	Private nHdlLog := nil
	Private cArqLog := "RJUJOBL1_"+dtos(DATE())+"_"+StrTran(cValToChar(time()),":","")+".log"  // arquivo de log das operaчєes

//┌────────────────────────────────────────────────────
//│Chama funчуo para monitor uso de fontes customizados│
//└────────────────────────────────────────────────────
	U_USORWMAKE(ProcName(),FunName())


	ConOut(Time() + " - " + cEmpAnt + cFilAnt + " - RJUJOBL1 - " + "INICIO")

	If cEmpAnt != nil .and. cFilAnt != nil

		//RpcClearEnv()
		//RPCSetType(3)
		//PREPARE ENVIRONMENT EMPRESA cEmpAnt FILIAL cFilAnt MODULO "FAT" TABLES "SL1"

		cEnvSrv := GetEnvServer()
		cRpoDb  := ALLTRIM(Upper(GetPvProfString(cEnvSrv, "RpoDb", "DBF", GetADV97())))

		dbSelectArea("SL1")
		dbSetOrder(1)
		dbGoTop()
		dbSeek(cFilAnt)
		While !SL1->(EOF()) .AND. SL1->L1_FILIAL == cFilAnt
			If ALLTRIM(SL1->L1_SITUA) == "ER" .AND. SL1->L1_X_PJOB != "S" 
				If RecLock("SL1",.F.)
					//--VERIFICA A VERSAO DO RPO QUE O JOB ESTA SENDO EXECUTADO, CASO SEJA DBF E' NA ESTACAO, CASO CONTRARIO NA RETAGUARDA.
					If cRpoDB == "DBF"
						//--PDV
						SL1->L1_SITUA	:= "00"
					Else
						//--RETAGUARDA
						SL1->L1_SITUA	:= "RX"
					EndIf
					SL1->L1_X_PJOB	:= "S"
					conout("Atulizando registro! " + SL1->L1_DOC )
					SL1->(MsUnLock())
				EndIf
			ElseIf ALLTRIM(SL1->L1_SITUA) == "ER" .AND. SL1->L1_X_PJOB == "S"
				If nHdlLog == nil
					If !fBegFile()
						CONOUT(TIME()+"RJUJOBL1-PROBLEMA NA CRIACAO DO ARQUIVO DE LOG.")
					EndIf
				EndIf
				If nHdlLog != nil
					cTEXTO := "L1_FILIAL = "+SL1->L1_FILIAL+" | L1_NUM = "+SL1->L1_NUM+" | L1_CLIENTE = "+SL1->L1_CLIENTE+" | L1_LOJA = "+SL1->L1_LOJA+" | L1_DOC = "+SL1->L1_DOC+" | L1_SERIE = "+SL1->L1_SERIE
					fWrtFile(cTEXTO)
				EndIf
			EndIf
			SL1->(dbSkip())
		Enddo

	Else
		CONOUT(TIME()+"RJUJOBL1-PROBLEMA COM O CODIGO DA EMPRESA/FILIAL.")
	EndIf

	If nHdlLog != nil
		fEndFile()
	EndIf

	ConOut(Time() + " - " + cEmpAnt + cFilAnt + " - RJUJOBL1 - " + "FIM")

Return



/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒╔══════════╤══════════╦═══════╤════════════════════╦══════╤═════════════╗▒▒
▒▒║Programa  │fBegFile    ║Autor  │Rafael Parma      ║ Data │  11/12/09   ║▒▒
▒▒╠══════════╪══════════╩═══════╧════════════════════╩══════╧═════════════╣▒▒
▒▒║Desc.     │Inicializaчуo do arquivo de log.                            ║▒▒
▒▒║          │                                                            ║▒▒
▒▒╠══════════╪════════════════════════════════════════════════════════════╣▒▒
▒▒║Uso       │TOTVS                                                       ║▒▒
▒▒╚══════════╧════════════════════════════════════════════════════════════╝▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/

Static Function fBegFile()
	Local lRet := .T.

	//┌─────────────────────────────────────────────────────────────────────┐
	//│ Cria o arquivo texto                                                │
	//└─────────────────────────────────────────────────────────────────────┘

	cDestino := "\RJULOBL1\"

	If !File(cDestino)
		MAKEDIR(cDestino)
	EndIf

	nHdlLog := fCreate((cDestino+cArqLog))

	If nHdlLog == -1
		lRet := .F.
	Endif

Return (lRet)

/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒╔══════════╤══════════╦═══════╤════════════════════╦══════╤═════════════╗▒▒
▒▒║Programa  │fWrtFile    ║Autor  │Rafael Parma      ║ Data │  11/12/09   ║▒▒
▒▒╠══════════╪══════════╩═══════╧════════════════════╩══════╧═════════════╣▒▒
▒▒║Desc.     │Escreve no arquivo de log.                                  ║▒▒
▒▒║          │                                                            ║▒▒
▒▒╠══════════╪════════════════════════════════════════════════════════════╣▒▒
▒▒║Uso       │TOTVS                                                       ║▒▒
▒▒╚══════════╧════════════════════════════════════════════════════════════╝▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/

Static Function fWrtFile(cLin)
	Local lRet := .T.
	Local cSTR := cLin

	cSTR := dtos(ddatabase)+"-"+cValToChar(time())+"-"+cSTR+chr(13)+chr(10)

	If fWrite(nHdlLog,cSTR,Len(cSTR)) != Len(cSTR)
		lRet := .F.
	EndIf

Return (lRet)

/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
