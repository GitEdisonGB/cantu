#INCLUDE "PARMTYPE.CH"
#DEFINE PAD_LEFT            0
#DEFINE PAD_RIGHT           1
#DEFINE PAD_CENTER          2

#DEFINE CDIRSRV "/data/fatauto/"
#DEFINE CLOCPDF "C:\Temp\"

/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒╔══════════č══════════╦═══════č════════════════════╦══════č═════════════╗▒▒
▒▒║Programa  │BOLASER_NEW     ║Autor  │J&@N          ║ Data │  30/05/12   ║▒▒
▒▒╠══════════ž══════════╩═══════Ž════════════════════╩══════Ž═════════════╣▒▒
▒▒║Desc.     │ Essa rotina tem como finalidade a emissŃo de boletos       ║▒▒
▒▒║          │ de Todos os Bancos.                                        ║▒▒
▒▒╠══════════ž════════════════════════════════════════════════════════════╣▒▒
▒▒║Uso       │ Financeiro/Faturamento                                     ║▒▒
▒▒╚══════════Ž════════════════════════════════════════════════════════════╝▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/

User Function Boletos(_cCli,_cLoja,_cDoc,_cPref,_cBco,_cAge,_cCta,_cSubCta,_lAuto,oPrint,lfFatAuto)

	Local nOpc         := 0
	Local aMarked      := {}
	Local aDesc        := {"Esta rotina imprime os boletos de","cobranca bancaria de acordo com","os parŌmetros informados."}

	Default lfFatAuto   := .F.
	Default oPrint	   := Nil

	Default _cBco	:= ""
	Default _cAge	:= ""
	Default _cCta	:= ""
	Default _cSubCta:= ""

	Private Exec       := .F.
	Private cIndexName := ''
	Private cIndexKey  := ''
	Private cFilter    := ''
	Private cPerg      := Padr("BOLETOS",len(sx1->x1_grupo))
	Private aMsg       := {}
	Private alRetTit   := {}

	/*
	Quando automßtico define para qual Banco deve gerar os boletos.
	Data : 2019-11-28  Desenv	: Fabio Sales
	*/

	IF lfFatAuto .AND. EMPTY(_cBco) .AND. EMPTY(_cAge) .AND. EMPTY(_cCta)

		alBco	:= U_FSFAT01D(FSFAT01B->A1_COD,FSFAT01B->A1_LOJA)

		IF LEN(alBco) > 0

			cpCodRg		:= alBco[1]
			_cBco		:= alBco[2]
			_cAge		:= alBco[3]
			_cCta		:= alBco[4]
			_cSubCta	:= alBco[5]
		ELSE
			cMsgAux	:= "NAO FOI POSSIVEL DEFIR O BANCO, AGNECIA E CONTA PARA GERACAO DO BOLETO AUTOMATICAMENTE. VERIFIQUE O CADASTRO DE RANGE BANCARIO."
			conout("### U_Boletos", cMsgAux)
			aAdd(aMsg, cMsgAux)
			Return
		ENDIF

	ENDIF

	//┌────────────────────────────────────────────────────
	//│Chama funńŃo para monitor uso de fontes customizados│
	//└────────────────────────────────────────────────────
	U_USORWMAKE(ProcName(),FunName())

	SetPrvt("AAC,ACRA,CNOMEREL,CFILE,CSAVSCR1,CSAVCUR1")
	SetPrvt("CSAVROW1,CSAVCOL1,CSAVCOR1,ANOTA,CALIAS,CSAVSCR3")
	SetPrvt("CCOLOR")
	SetPrvt("CTELA,AFILE,CSAVSCR,I,CSAVCOR,NOPCFILE")
	SetPrvt("NOPCA,NTREGS,NMULT,NANT,NATU,NCNT")
	SetPrvt("NTOTPORCEN,CSAV20,CSAV7,NDIA,CBARRA,CLINHA,cBarraImp,cBarraFim")
	SetPrvt("NDIGITO,CCAMPO,NCONT,NVAL,instr1,instr2,cBarraImp4,X,NOSSONUM,cCondicao")

	Private _auto	:= .F.

	Tamanho  := "M"
	titulo   := "ImpressŃo de Boletos"
	cDesc1   := "Este programa destina-se a impressŃo de boletos de todos os bancos."
	cDesc2   := ""
	cDesc3   := ""
	cString  := "SE1"
	wnrel    := "BOLETOS"
	lEnd     := .F.
	aReturn  := {"Zebrado", 1,"Administracao", 2, 2, 1, "",1 }
	nLastKey := 0

	dbSelectArea("SE1")

	If ValType(_lAuto) == "U"
		ValidPerg(cPerg)

		if !Pergunte(cPerg, .T.)
			Return
		EndIf

		//┌────────────────────────────────────────────────────────────────────────────X┐
		//│Valida se o campo A6_EMITBOL estß como verdadeiro para a emissŃo de boletos.│
		//└────────────────────────────────────────────────────────────────────────────X┘

		if (MV_PAR15 == 2) .And. !U_ValidBco(MV_PAR16, MV_PAR17, MV_PAR18)
			aAdd(aMsg, "A OPŪ├O 'EMITE BOLETO' NO CADASTRO DO BANCO "+ Trim(MV_PAR16) +" AGENCIA "+ Trim(MV_PAR17) +" E CONTA "+ Trim(MV_PAR18)+" EST┴ DESABILITADA.")
			Return
		EndIf

		//┌───────────────────────────────────────────────────────────────────────────┐
		//│Verifica se o banco selecionado pode ser utilizado para emissŃo de boletos.│
		//└───────────────────────────────────────────────────────────────────────────┘

		if !MV_PAR16 $ "001/004/033/104/133/224/237/246/320/341/399/422/439/460/623/655/707/745/748/756/600"
			aAdd(aMsg, "O BANCO " + AllTrim(MV_PAR16) + " N├O EST┴ PREPARADO PARA EMITIR BOLETOS.")
			Return
		EndIf

		If nLastKey == 27
			Set Filter to
			Return
		EndIf

		nOpc := 1

	Else
		Pergunte(cPerg, .F.)
		nOpc  := 2
		_auto := .T.
	Endif

	if nOpc == 1

		/*-------------------------------------------------------------------------------------------------
		Faturamento automßtico.
		ALERTA ao usuario caso selecione banco agencia e conta diferente o
		range bancßrio ativo.
		---------------------------------------------------------------------------------------------------*/
		clQuery := " SELECT ZFA_CODIGO,ZFA_BANCO,ZFA_AGENCI,ZFA_CONTA,ZFA_SALDO FROM "+RETSQLNAME("ZFA")+" ZFA  "
		clQuery += " WHERE ZFA.D_E_L_E_T_<>'*' "
		clQuery += " AND ZFA_STATUS = '1' "
		clQuery += " AND ZFA_SALDO > 0 "
		clQuery += " ORDER BY ZFA_PRIORI "

		IF SELECT("ZFA1") <> 0
			ZFA1->(DBCLOSEAREA())
		ENDIF

		TCQUERY clQuery NEW ALIAS "ZFA1"
		/*
		IF !ZFA1->(EOF()) .AND. mv_Par15 <> 1
			IF ALLTRIM(ZFA1->ZFA_BANCO) <> ALLTRIM(MV_PAR16).OR.;
			ALLTRIM(ZFA1->ZFA_AGENCI) <> ALLTRIM(MV_PAR17) .OR.;
			ALLTRIM(ZFA1->ZFA_CONTA) <> ALLTRIM(MV_PAR18)

				cAux := "Conforme parametrizado na tabela de Range Bancßrios, "
				cAux += "existe saldo disponivel em banco agencia e conta diferente do selecionado. "+CRLF+CRLF
				cAux += "Deseja seguir com o Banco, Agencia e Conta selecionado ou revisar os parametros?"+CRLF+CRLF
				cAux += "RANGE BANC┴RIO "+CRLF
				cAux += "SALDO:  "+AllTrim(Transform(ZFA1->ZFA_SALDO," @E 999,999,999.99"))+CRLF
				cAux += "BANCO: "+AllTrim(ZFA1->ZFA_BANCO)+CRLF
				cAux += "AGENCIA: "+AllTrim(ZFA1->ZFA_AGENCI)+CRLF
				cAux += "CONTA: "+AllTrim(ZFA1->ZFA_CONTA)+CRLF
				nOpcAux	:= Aviso("RANGE BANC┴RIO DISPONIVEL", cAux, {"PROSSEGUIR","CANCELAR"}, 3)
					IF nOpcAux == 2
					RETURN
				ELSE
					MV_PAR16	:= ZFA1->ZFA_BANCO
					MV_PAR17	:= ZFA1->ZFA_AGENCI
					MV_PAR18	:= ZFA1->ZFA_CONTA
					//MV_PAR19  := _cSubCta
				ENDIF

			ENDIF
		ENDIF
		*/
		DBCLOSEAREA("ZFA1")

		cIndexName := Criatrab(Nil,.F.)
		cIndexKey  := 	"E1_PREFIXO+E1_NUM+E1_PARCELA+E1_PORTADO+E1_CLIENTE+E1_TIPO+DTOS(E1_EMISSAO)"

		cFilter    := 	"E1_PREFIXO >= '" + MV_PAR01 + "' .And. E1_PREFIXO <= '" + MV_PAR02 + "' .And. " + ;
			"E1_NUM     >= '" + MV_PAR03 + "' .And. E1_NUM     <= '" + MV_PAR04 + "' .And. " + ;
			"E1_PARCELA >= '" + MV_PAR05 + "' .And. E1_PARCELA <= '" + MV_PAR06 + "' .And. " + ;
			"E1_CLIENTE >= '" + MV_PAR07 + "' .And. E1_CLIENTE <= '" + MV_PAR08 + "' .And. " + ;
			"E1_EMISSAO >= CTOD('" + DTOC(MV_PAR13) + "') .And. E1_EMISSAO <= CTOD('" + DTOC(MV_PAR14) + "') .And. " + ;
			"E1_VENCTO  >= CTOD('" + DTOC(MV_PAR11) + "') .And. E1_VENCTO  <= CTOD('" + DTOC(MV_PAR12) + "') .And. " + ;
			"E1_LOJA    >= '" + MV_PAR09 + "' .And. E1_LOJA    <= '" + MV_PAR10 + "' .And. " + ;
			"E1_FILIAL   = '" + xFilial("SE1") + "' .And. E1_SALDO > 0 .And. E1_XCODAUT = ' ' .And. E1_BOLETO <> '2' .And. " + ;
			"(Alltrim(E1_TIPO) = 'NF' .Or. Alltrim(E1_TIPO) = 'FT' .Or. Alltrim(E1_TIPO) = 'DP' .Or. Alltrim(E1_TIPO) = 'BO')"

		//┌───────────┐
		//│ReimpressŃo│
		//└───────────┘

		if mv_Par15 == 1
			cFilter +=" .And. !Empty(E1_NUMBCO)"
		else
			cFilter +=" .And. Empty(E1_NUMBCO)"
		endif

		IndRegua("SE1", cIndexName, cIndexKey,, cFilter, "Aguarde selecionando registros....")
		dbSelectArea("SE1")

		#IFNDEF TOP
			dbSetIndex(cIndexName + OrdBagExt())
		#ENDIF

		dbGoTop()

		//┌─────────────────────────────────────────────────────────────────────────┐
		//│Se usußrio deseja visualizar e selecionar os tĒtulos pra gerar os boletos│
		//└─────────────────────────────────────────────────────────────────────────┘

		if MV_PAR20 == 1

			@ 001,001 TO 400,700 DIALOG oDlg TITLE "TĒtulos Selecionados para ImpressŃo"
			@ 001,001 TO 170,350 BROWSE "SE1" MARK "E1_OK"
			@ 180,310 BMPBUTTON TYPE 01 ACTION (Exec := .T.,Close(oDlg))
			@ 180,280 BMPBUTTON TYPE 02 ACTION (Exec := .F.,Close(oDlg))

			ACTIVATE DIALOG oDlg CENTERED

			dbGoTop()
			Do While !Eof()
				If Marked("E1_OK")
					DbSelectArea("SE1")
					AADD(aMarked,.T.)
				Else
					AADD(aMarked,.F.)
				EndIf
				dbSkip()
			EndDo

		Else
			DbSelectArea("SE1")
			DbGoTop()
			Do While !Eof()
				DbSelectArea("SE1")
				AADD(aMarked,.T.)
				Exec := .T.
				dbSkip()
			EndDo
		EndIf

		DbGoTop()

		nLock := 0
		nSeg  := 0

		If Exec

			//┌─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐
			//│Controle de semßfoto para que um usußrio nŃo consiga gerar boletos no mesmo momento em que outro usußrio estiver gerando para a mesma empresa│
			//└─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘

			/* 20/06/16 - GUSTAVO LATTMANN
			If MV_PAR15 != 1
				While !LockByName("BOLETOS"+cEmpAnt,.T.,.F.,.T.)
			Processa({|| fAguarda(10) }, "Aguarde...", "Jß existe outro usußrio emitindo boleto, a rotina vai aguardar 10 segundos e tentar novamente!", .F.)
				EndDo
			EndIf
			20/06/2016 - FIM GUSTAVO */

			RptStatus({|lEnd| MontaRel(@lEnd, aMarked)}, "Aguarde...", "Gerando Boletos...", .T.)

			If MV_PAR15 != 1
				UnLockByName("BOLETOS"+cEmpAnt, .T., .F., .T.)
			EndIf

		EndIf

		RetIndex("SE1")

		fErase(cIndexName+OrdBagExt())

		//┌──────────────────────────────────────────────────────────────┐
		//│Cai nessa excessŃo, caso a esteja fazendo a emissŃo automßtica│
		//└──────────────────────────────────────────────────────────────┘

	Else

		MV_PAR15	:= 2
		MV_PAR16	:= _cBco
		MV_PAR17	:= _cAge
		MV_PAR18	:= _cCta
		MV_PAR19  := _cSubCta

		//┌────────────────────────────────────────────────────────────────────────────X┐
		//│Valida se o campo A6_EMITBOL estß como verdadeiro para a emissŃo de boletos.│
		//└────────────────────────────────────────────────────────────────────────────X┘

		if (MV_PAR15 == 2) .And. .F. //!U_ValidBco(MV_PAR16, MV_PAR17, MV_PAR18)
			aAdd(aMsg, "A OPŪ├O 'EMITE BOLETO' NO CADASTRO DO BANCO "+ Trim(MV_PAR16) +" AGENCIA "+ Trim(MV_PAR17) +" E CONTA "+ Trim(MV_PAR18)+" EST┴ DESABILITADA.")
			Return
		EndIf

		//┌───────────────────────────────────────────────────────────────────────────┐
		//│Verifica se o banco selecionado pode ser utilizado para emissŃo de boletos.│
		//└───────────────────────────────────────────────────────────────────────────┘

		if !MV_PAR16 $ "001/004/033/104/133/224/237/246/320/341/422/439/460/623/655/707/745/748/756/600"
			aAdd(aMsg, "O BANCO " + AllTrim(MV_PAR16) + " N├O EST┴ PREPARADO PARA EMITIR BOLETOS.")
			Return
		EndIf

		DbSelectArea("SE1")
		cIndexName := Criatrab(Nil,.F.)
		cIndexKey  := "E1_PREFIXO+E1_NUM+E1_PARCELA+E1_PORTADO+E1_CLIENTE+E1_TIPO+DTOS(E1_EMISSAO)"
		cFilter    := "E1_PREFIXO >= '" + _cPref + "' .And. E1_PREFIXO <= '" + _cPref + "' .And. " + ;
			"E1_NUM     >= '" + _cDoc  + "' .And. E1_NUM     <= '" + _cDoc  + "' .And. " + ;
			"E1_CLIENTE >= '" + _cCli  + "' .And. E1_CLIENTE <= '" + _cCli  + "' .And. " + ;
			"E1_LOJA    >= '" + _cLoja + "' .And. E1_LOJA    <= '" + _cLoja + "' .And. " + ;
			"E1_FILIAL   = '" + xFilial("SE1") + "' .And. E1_SALDO > 0 .And. E1_XCODAUT = ' ' .And. E1_BOLETO <> '2' .And." + ;
			"(Alltrim(E1_TIPO)='NF' .Or. Alltrim(E1_TIPO)='FT' .Or. Alltrim(E1_TIPO)='DP' .Or. Alltrim(E1_TIPO) = 'BO')"

		//|cFilter    += " .And. Empty(E1_NUMBCO)"

		IndRegua("SE1", cIndexName, cIndexKey,, cFilter, "Buscando TĒtulos para EmissŃo dos Boletos....")
		dbSelectArea("SE1")

		#IFNDEF TOP
			dbSetIndex(cIndexName + OrdBagExt())
		#ENDIF

		dbGoTop()
		Do While !Eof()
			AADD(aMarked,.T.)
			Exec := .T.
			dbSkip()
		EndDo
		dbGoTop()

		nLock := 0
		nSeg  := 0
		If Exec .and. !_auto

			//┌─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐
			//│Controle de semßfoto para que um usußrio nŃo consiga gerar boletos no mesmo momento em que outro usußrio estiver gerando para a mesma empresa│
			//└─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘
			/* 20/06/16 - GUSTAVO LATTMANN
			If MV_PAR15 != 1
				While !LockByName("BOLETOS"+cEmpAnt,.T.,.F.,.T.)
			Processa({|| fAguarda(10) }, "Aguarde...", "Jß existe outro usußrio emitindo boleto, a rotina vai aguardar 10 segundos e tentar novamente!", .F.)
				EndDo
			EndIf
			20/06/16 - FIM GUSTAVO LATTMANN */

			RptStatus({|lEnd| MontaRel(@lEnd, aMarked)}, "Aguarde...", "Gerando Boletos...", .T.)

			If MV_PAR15 != 1
				UnLockByName("BOLETOS"+cEmpAnt, .T., .F., .T.)
			EndIf

		ElseIf Exec .and. _auto

			//┌─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐
			//│Controle de semßfoto para que um usußrio nŃo consiga gerar boletos no mesmo momento em que outro usußrio estiver gerando para a mesma empresa│
			//└─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘
			/* 20/06/16 - GUSTAVO LATTMANN
			if MV_PAR15 != 1
				While !LockByName("BOLETOS"+cEmpAnt,.T.,.F.,.T.)
			nLock += 1
			Sleep(1000)
					If nLock == 10
			nSeg += nLock
			ConOut("BOLETOS - Rotina aguardando o controle de semßforo ("+ AllTrim(cValtoChar(nSeg)) +"s)")
			nLock := 0
					EndIf
				EndDo
			EndIf
			20/06/16 - FIM GUSTAVO LATTMANN */

			MontaRel(@lEnd, aMarked,@oPrint,lfFatAuto)

			If MV_PAR15 != 1
				UnLockByName("BOLETOS"+cEmpAnt, .T., .F., .T.)
			EndIf

		Endif

		RetIndex("SE1")
		fErase(cIndexName+OrdBagExt())

	Endif

	//┌─────────────────────────────────────────────────────┐
	//│Mostra mensagens de processamento ao final da rotina.│
	//└─────────────────────────────────────────────────────┘

	cTmp := ""
	if Len(aMsg) > 0 .and. !_auto
		for i := 1 to Len(aMsg)
			cTmp += aMsg[i] + CHR(13)+CHR(10)
		Next i

		Aviso("ENTRE EM CONTATO COM A AREA DE CREDITO", cTmp, {"Ok"}, 3)

	ElseIf  Len(aMsg) > 0 .and. _auto
		for i := 1 to Len(aMsg)
			ConOut( aMsg[i] )
		Next i
	EndIf

	IF lfFatAuto

		aMsg := alRetTit

	ENDIF

Return aMsg

/*
	▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
	▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
	▒▒╔══════════č══════════╦═══════č════════════════════╦══════č═════════════╗▒▒
	▒▒║Programa  │MONTAREL ║Autor  │Jean C. P. Saggin    ║ Data │  27/01/14   ║▒▒
	▒▒╠══════════ž══════════╩═══════Ž════════════════════╩══════Ž═════════════╣▒▒
	▒▒║Desc.     │ FunńŃo responsßvel pela montagem do boleto grßfico.        ║▒▒
	▒▒║          │                                                            ║▒▒
	▒▒╠══════════ž════════════════════════════════════════════════════════════╣▒▒
	▒▒║Uso       │ Faturamento/Financeiro                                     ║▒▒
	▒▒╚══════════Ž════════════════════════════════════════════════════════════╝▒▒
	▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
	▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
			*-----------------------------------------*
Static Function MontaRel(lEnd, aMarked,oPrint,lfFatAuto)
	*-----------------------------------------*

	Local nHeight   := 15
	Local lBold     := .F.
	Local lUnderLine:= .F.
	Local lPixel    := .T.
	Local lPrint    := .F.
	Local nPag
	Local nTPag     := 1
	Local nLin      := 0
	Local cPeriodo
	Local lVisual   := .T.
	Local lSend := .F.
	Local nDescfin  := 0
	Local nDecrecs  := 0
	Local nSaldo  := 0
	Default lfFatAuto	:= .F.
	Private M->FatorVcto := ""
	Private M->FatVtoSic := ""
	Private M->NumBoleta := ""
	Private M->CodBarras := ""
	Private M->LinhaDig  := ""
	Private dvBol        := "  "
	Private lContinua    := .T.
	Private _BarPubl
	Private _bLivre
	Private nValLiq      := 0
	Private aMensagem    := {}
	Private aDadosBanco  := {}
	Private aEmail       := {}
	Private aDadosEnvi   := {}
	Private cNomePDF     := "default.rel"
	Private oPrn
	Private oPrnPDF
	Private lAdjustToLegacy := .T.
	Private lDisableSetup   := .T.
	Private cFilePrint      := ""
	Private aFiles           := {}

	oPrn	:= @oPrint

	//If !_auto
	//	Pergunte(cPerg,.F.)
	//Endif

	cBanco   := MV_PAR16
	cAgencia := MV_PAR17
	cConta   := MV_PAR18
	cSubCta  := MV_PAR19
	cLinha   := ""

	//┌─────────────────────────────┐
	//│Valida Banco, AgĻncia e Conta│
	//└─────────────────────────────┘

	dbSelectArea("SA6")
	dbSetOrder(1)
	dbGotop()
	If !dbSeek(xFilial("SA6")+ AVKEY(cBanco,"A6_COD") + AVKEY(cAgencia,"A6_AGENCIA") + cConta)
		aAdd(aMsg, "BANCO "+ Trim(cBanco) + " AG╩NCIA "+ Trim(cAgencia) + " OU CONTA "+ Trim(cConta) +;
			" NAO ENCONTRADOS.")
		Return
	EndIf

	//┌─────────────────────────────────────────────────
	//│Posiciona na tabela de parŌmetros de Bancos (SEE)
	//└─────────────────────────────────────────────────

	dbSelectArea("SEE")
	dbSetOrder(1)
	if !dbSeek(xFilial("SEE") + AVKEY(cBanco,"EE_CODIGO") + AVKEY(cAgencia,"EE_AGENCIA") + AVKEY(cConta,"EE_CONTA")  + cSubCta)
		aAdd(aMsg, "OS PAR┬METROS DO BANCO "+Trim(cBanco)+", AG╩NCIA "+Trim(cAgencia)+", CONTA "+Trim(cConta)+" E SUBCONTA "+Trim(cSubCta)+;
			" PRECISAM ESTAR CADASTRADOS PARA QUE OS BOLETOS POSSAM SER EMITIDOS.")
		Return
	EndIf

	//┌────────────────────────────────────────────────────────────────────────┐
	//│Busca quantidade de dias de protesto do cadastro de ParŌmetros de Bancos│
	//└────────────────────────────────────────────────────────────────────────┘

	nDiasProtesto := SEE->EE_DIASPRO

	//┌──────────────────────────
	//│ Pega dados do Banco (SA6)
	//└──────────────────────────

	dbSelectArea("SA6")
	aDadosBanco := {SA6->A6_COD,;                  // 01 C¾digo do Banco
	Trim(SA6->A6_NOME),;                           // 02 Nome do Banco
	Trim(SEE->EE_AGENCIA),;                        // 03 AgĻncia
	Trim(SEE->EE_DVAGE),;                          // 04 DĒgito Verificador AgĻncia
	Trim(SEE->EE_CONTA),;                          // 05 Conta Corrente
	Trim(SEE->EE_DVCTA),;                          // 06 DĒgito Verificador Conta
	"N",;                                          // 07 Aceite S/N
	Trim(SEE->EE_CARTVAR),;                        // 08 Carteira de Cobranca
	Trim(SEE->EE_CODEMP),;                         // 09 C¾digo da Empresa
	Trim(SEE->EE_X_COSMO),;                        // 10 Conta Cosmo (Santander)
	Trim(SEE->EE_X_AGCOR),;                        // 11 AgĻncia Bco Corresp
	Trim(SEE->EE_X_CTACO),;                        // 12 Conta Bco Corresp
	Trim(SEE->EE_FORMEN1)}                         // 13 Mensagem beneficiario fidcs
	dbSelectArea("SE1")

	//┌──────────────────────────────────────────────────┐
	//│Cßlculo do dĒgito verificador do c¾digo da empresa│
	//└──────────────────────────────────────────────────┘

	aDadosBanco[09] := fDadosBanco(aDadosBanco)

	//┌─────────────────────────────────
	//│ Inicializa Objetos de Impressao
	//└─────────────────────────────────

	If !_auto
		oPrn := TMSPrinter():New()
		oPrn:SetPortrait()

		oPrn:Setup()

		SetRegua(Len(aMarked))

	Endif

	WHILE SE1->(!EOF())
		If !_auto
			IncRegua()
			If !Marked("E1_OK")
				dbSelectArea("SE1")
				dbSkip()
				Loop
			Endif
		Endif

		DbSelectArea("SA1")
		DbSetOrder(1)
		DbSeek(xFilial("SA1") + SE1->E1_CLIENTE + SE1->E1_LOJA, .T. )

		//┌──────────────────────────────────────────────────────────────────────────────────────┐
		//│ValidańŃo para desconsiderar clientes cuja forma de pagamento for diferente de boleto.│
		//└──────────────────────────────────────────────────────────────────────────────────────┘

		if Trim(SA1->A1_FORMPAG) != "BO"
			aAdd(aMsg, "TITULO: "+Trim(SE1->E1_NUM)+ iif(!Empty(SE1->E1_PARCELA)," "+SE1->E1_PARCELA+" "," ") +;
				" => FORM. DE PGTO CLIENTE "+ Trim(SE1->E1_CLIENTE) + " LOJA " + SE1->E1_LOJA +" ╔ DIFERENTE DE BOLETO.")

			if _auto
				lFim := .T.
			EndIf

			dbSelectArea("SE1")
			SE1->(dbSkip())
			Loop
		EndIf

		/*--------------------------------------------------------------
		Validacao para desconsiderar clientes com exceńŃo de banco
		----------------------------------------------------------------*/
		DBSELECTAREA("ZFC")
		ZFC->(DBSETORDER( 1 ))
		IF DBSEEK( XFILIAL("ZFC")+SE1->E1_CLIENTE + SE1->E1_LOJA+cBanco,.F.)
			aAdd(aMsg, "TITULO: "+Trim(SE1->E1_NUM)+ iif(!Empty(SE1->E1_PARCELA)," "+SE1->E1_PARCELA+" "," ") +;
				" => CLIENTE COM RESTRIŪ├O PARA EMISS├O DE BOLETO PARA BANCO "+ALLTRIM(cBanco)+" TABELA")

			dbSelectArea("SE1")
			SE1->(dbSkip())
			Loop
		ENDIF

		//┌─────────────────────┐
		//│Valida CEP do Cliente│
		//└─────────────────────┘
		lBcoValCep := .F.
		lBcoValCep := cBanco $ "224/320/623/745"

		if lBcoValCep .and. MV_PAR15 != 1
			if cBanco $ "224/320/623"

				if !U_ValCepBrd("237", SA1->A1_CEP)
					aAdd(aMsg, "TITULO: "+Trim(SE1->E1_NUM)+ iif(!Empty(SE1->E1_PARCELA)," "+SE1->E1_PARCELA+" "," ") +;
						" => N├O H┴ AG╩NCIA BRADESCO PARA O CEP "+Transform(SA1->A1_CEP,"@R 99999-999")+" DO CLIENTE "+ Trim(SE1->E1_CLIENTE) + " LOJA " + SE1->E1_LOJA +".")
					dbSelectArea("SE1")
					SE1->(dbSkip())
					Loop
				EndIf

				//┌──────────────────────────────────────────────┐
				//│ValidańŃo do CEP na emissŃo do boleto Citibank│
				//└──────────────────────────────────────────────┘

			ElseIf cBanco == "745"
				if !U_ValCepFaixa("745", SA1->A1_EST, SA1->A1_CEP)
					aAdd(aMsg, "TITULO: "+Trim(SE1->E1_NUM)+ iif(!Empty(SE1->E1_PARCELA)," "+SE1->E1_PARCELA+" "," ") +;
						" => N├O H┴ PRAŪA CITIBANK PARA O CEP "+Transform(SA1->A1_CEP,"@R 99999-999")+" DO CLIENTE "+ Trim(SE1->E1_CLIENTE) + " LOJA " + SE1->E1_LOJA +".")
					dbSelectArea("SE1")
					SE1->(dbSkip())
					Loop
				EndIf

			EndIf
		EndIf

		DbSelectArea("SE1")
		
		nValLiq := Round(SE1->E1_SALDO, 2)
		

		//┌────────────┐
		//│1¬ ImpressŃo│
		//└────────────┘

		if Empty(SE1->E1_NUMBCO)

			//┌─────────────────────────────────┐
			//│Forma sequencial do nosso n·mero.│
			//└─────────────────────────────────┘

			cNumBco := fSeqNNro(SEE->EE_FAXATU)

			//┌───────────────────────────────────────────────────────────────────────────────┐
			//│Valida se o n·mero sequencial estß entre a faixa numķrica estipulada pelo banco│
			//└───────────────────────────────────────────────────────────────────────────────┘

			if (Val(cNumBco) < Val(SEE->EE_FAXINI) .or. Val(cNumBco) > Val(SEE->EE_FAXFIM))
				aAdd(aMsg, "SEQU╩NCIA NUMERO "+AllTrim(cNumBco)+" FORA DA FAIXA PERMITIDA NO CADASTRO DE PAR┬METROS DE BANCOS, ENTRE EM CONTATO COM O FINANCEIRO (FAVOR N├O EMITIR MAIS BOLETOS NESSA CONTA.).")
				Return
			endIf

			cSequencia   := AllTrim(cNumBco)
			M->NumBoleta := fGerNNro(cSequencia)
			dvBol 		   := fCalcDvNN(M->NumBoleta)
			_lGravaNNum  := .T.

		Else

			//┌───────────────────────────────────────────────────────────────────────────────────────┐
			//│Bloqueio para fins de compatibilidade com a carteira vigente da Caixa Econ¶mica Federal│
			//└───────────────────────────────────────────────────────────────────────────────────────┘

			If SE1->E1_EMISSAO <= StoD("20150519") .and. SE1->E1_PORTADO == '104' .and. Len(aDadosBanco[09]) != 12  //Caixa Econ¶mica Federal
				aAdd(aMsg, "TITULO: "+Trim(SE1->E1_NUM)+ iif(!Empty(SE1->E1_PARCELA)," "+SE1->E1_PARCELA+" "," ") +;
					" => O T═TULO FOI IMPRESSO EM OUTRA MODALIDADE DE COBRANCA, POR ISSO NAO PODERA SER REIMPRESSO!")
				SE1->(dbSkip())
				Loop
			EndIf

			//┌───────────────────────────────────────────────────────────────────────────────────────────────────────────────
			//│Valida se o boleto foi impresso em outro banco para evitar erro de recßlculo de nosso n·mero e c¾digo de barras│
			//└───────────────────────────────────────────────────────────────────────────────────────────────────────────────

			If AllTrim(SE1->E1_PORTADO) != aDadosBanco[01] .or. AllTrim(SE1->E1_AGEDEP) != aDadosBanco[03] .or. AllTrim(SE1->E1_CONTA) != aDadosBanco[05]
				aAdd(aMsg, "TITULO: "+Trim(SE1->E1_NUM)+ iif(!Empty(SE1->E1_PARCELA)," "+SE1->E1_PARCELA+" "," ") +;
					" => O T═TULO J┴ FOI REGISTRADO NO BANCO "+SE1->E1_PORTADO+" AGENCIA: "+SE1->E1_AGEDEP+" CONTA "+SE1->E1_CONTA+".")
				dbSelectArea("SE1")
				SE1->(dbSkip())
				Loop
			Endif

			M->NumBoleta := fMontaSeq(SE1->E1_NUMBCO)
			dvBol 		   := fCalcDvNN(M->NumBoleta)
			_lGravaNNum := .F.
		Endif

		//┌─────────────────────────────────────────────────────┐
		//│Valida se o nosso n·mero jß existe antes de gravß-lo.│
		//└─────────────────────────────────────────────────────┘

		lNNOk := U_ValidNNum(aDadosBanco[01], aDadosBanco[05], AllTrim(M->NumBoleta)+AllTrim(dvBol)) //Edison G. Barbieri 14/01/22 adiconado para validar conta
		While (!lNNOk .And. Empty(SE1->E1_NUMBCO))
			cSequencia   := fSeqNNro(SEE->EE_FAXATU)
			M->NumBoleta := fGerNNro(cSequencia)
			dvBol		     := fCalcDvNN(M->NumBoleta)
			lNNOk := U_ValidNNum(aDadosBanco[01], aDadosBanco[05], AllTrim(M->NumBoleta)+AllTrim(dvBol)) //Edison G. Barbieri 14/01/22 adiconado para validar conta
		EndDo

		//┌──────────────────────────────────────
		//│ Grava dados no SE1 (Titulos Receber)
		//└──────────────────────────────────────

		dbSelectArea("SE1")

		If _lGravaNNum .And. (mv_Par15 != 1)
			RecLock("SE1",.F.)
			SE1->E1_NUMBCO := AllTrim(M->NumBoleta) + AllTrim(dvBol)
			If !SEE->(EOF())
				SE1->E1_PORTADO := SEE->EE_CODIGO
				SE1->E1_AGEDEP  := SEE->EE_AGENCIA
				SE1->E1_CONTA   := SEE->EE_CONTA

			EndIf
			DbCommit()
			MsUnlock("SE1")
		Endif

		dbSelectArea("SE1")

		_dDataVencto := SubStr(DtoS(SE1->E1_VENCTO),7,2)+"/"+SubStr(DtoS(SE1->E1_VENCTO),5,2)+"/"+SubStr(DtoS(SE1->E1_VENCTO),1,4)

		aMensagem := {}

		//┌────────────────────────────
		//│Particularidade do banco ABC│
		//└────────────────────────────

		if aDadosBanco[01] == "246"
			Aadd(aMensagem, "TĒtulo transferido a favor do Banco ABC Brasil")
		EndIf

		//┌──────────────────────────────────┐
		//│Particularidade do Banco do Brasil│
		//└──────────────────────────────────┘

		if aDadosBanco[01] == "001"
			Aadd(aMensagem, "NŃo dispensar juros de mora.")
		EndIf

		//┌──────────────────────────── ┐
		//│Particularidade do Bic Banco│
		//└──────────────────────────── ┘

		if aDadosBanco[01] == "320"
			Aadd(aMensagem, "Tit. cedido fiduciariamente, nŃo pagar diretamente Ó "+Upper(Trim(SubStr(SM0->M0_NOMECOM, 01, 30)))+".")

		Endif

		//┌───────────────────────────────────────────────────────────────┐
		//│Verifica se existe percentual de multa cadastrado para o banco─┐
		//particularidade fidic creditise                                .│
		//└───────────────────────────────────────────────────────────────┘

		if SA6->A6_X_JUROS > 0 .and. aDadosBanco[05] == "0002364"
			Aadd(aMensagem, "Cobrar mora de "+AllTrim(Transform((SA6->A6_X_JUROS)," @E 99,999.99")) + "% a.m. de atraso")
		EndIf

		if SA6->A6_X_MULTA > 0 .and. aDadosBanco[05] == "0002364"
			Aadd(aMensagem, "Ap¾s o vencimento cobrar multa de "+AllTrim(Transform((SA6->A6_X_MULTA)," @E 99,999.99")) + "%" )
		EndIf

		//┌───────────────────────────────────────────────────────────────┐
		//│Verifica se existe percentual de multa cadastrado para o banco.│
		//└───────────────────────────────────────────────────────────────┘

		if SA6->A6_X_MULTA > 0  .and. aDadosBanco[05] != "0002364"
			Aadd(aMensagem, "Ap¾s "+ _dDataVencto +" cobrar multa de R$ "+AllTrim(Transform((nValLiq*(SA6->A6_X_MULTA/100)),"@E 99,999.99")))
		EndIf

		//┌───────────────────────────────────────────────────────────────┐
		//│Verifica se existe percentual de juros cadastrado para o banco.│
		//└───────────────────────────────────────────────────────────────┘

		if SA6->A6_X_JUROS > 0  .and. aDadosBanco[05] != "0002364"
			Aadd(aMensagem, "Ap¾s "+ _dDataVencto +" cobrar juros/mora dißria de R$ " +AllTrim(Transform(((nValLiq*(SA6->A6_X_JUROS/100))/30)," @E 99,999.99")))
		EndIf

		//┌───────────────────────────────────────────────────────────────┐
		//│Verifica se existe acrescimo para o titulo                    .│
		//└───────────────────────────────────────────────────────────────┘

		if SE1->E1_ACRESC > 0
			Aadd(aMensagem, "Cobrar Acrķscimo de R$ " +AllTrim(Transform(se1->e1_acresc," @E 99,999.99")))
		EndIf

		//┌───────────────────────────────────────────────────┐
		//│Verifica se estß habilitado o parŌmetro "Protestar"│
		//└───────────────────────────────────────────────────┘

		if SEE->EE_PROTEST .or. SuperGetMv("MV_MSGPROT",,.F.)
			If !Empty(nDiasProtesto) .and. aDadosBanco[05] != "0002364"
				Aadd(aMensagem, "Sujeito a protesto ap¾s "+ nDiasProtesto+" dias do vencimento.")
			EndIf
			//particularidade para banco creditise
			If !Empty(nDiasProtesto) .and. aDadosBanco[05] == "0002364"
				Aadd(aMensagem, "Protestar ap¾s "+ nDiasProtesto+" dias de vencido.")
			EndIf
		EndIf

		//┌─────────────────────
		//│JEAN - 08/05 - FINAL
		//└─────────────────────

		//┌────────────────────────────────────────────────
		//│Verifica se o tĒtulo tem desconto incondicional.
		//└────────────────────────────────────────────────

		If (SE1->E1_SDDECRE > 0)
			Aadd(aMensagem, "Conceder abatimento no valor de R$ " +AllTrim(Transform(SE1->E1_SDDECRE,PesqPict("SE1","E1_VALOR"))))
		EndIf

		//┌──────────────────────────────────────────────
		//│Verifica se o tĒtulo tem desconto condicional.
		//└──────────────────────────────────────────────

		If (SE1->E1_DESCFIN > 0)
			Aadd(aMensagem, "Para pagamento atķ " + Transform(SE1->E1_VENCTO,"@E") + " conceder desconto de R$ " +AllTrim(Transform((e1_valor*e1_descfin/100)," @E 99,999.99")))
			//AllTrim(Transform(SE1->E1_DESCONT,PesqPict("SE1","E1_VALOR")))) EDISON, N├O ESTA MAIS GRAVANDO O CAMPO E1_DESCONT, NECESSARIO FAZER O C┴CLULO

		endIf

		//┌─────────────────────────────────────────────────────────┐
		//│Particularidade do BIC para impressŃo de dados da Empresa│
		//└─────────────────────────────────────────────────────────┘

		if aDadosBanco[01] == "320"
			Aadd(aMensagem, Upper(Trim(SM0->M0_NOMECOM)) + " CNPJ: "+ Transform(SM0->M0_CGC,"@R 99.999.999/9999-99"))
			Aadd(aMensagem, Upper(Trim(SM0->M0_ENDENT)))
			Aadd(aMensagem, SubStr(SM0->M0_CEPENT,01,02) +"."+ SubStr(SM0->M0_CEPENT,03,03) +"-"+ SubStr(SM0->M0_CEPENT,06,03) +;
				" "+ Upper(Trim(SM0->M0_CIDENT)) + " " + SM0->M0_ESTENT)
		EndIf

		//┌────────────────────────────────────────────────────────┐
		//│ Imprime o Boleto referente ao Titulo atual (objeto oPrn)│
		//└────────────────────────────────────────────────────────┘

		//aEmail := {}

		aAdd(aEmail, {Upper(AllTrim(SubStr(Posicione("SA1",1, xFilial("SA1") + SE1->E1_CLIENTE + SE1->E1_LOJA, "A1_NOME"),01,30))),;
			Posicione("SA1",1, xFilial("SA1") + SE1->E1_CLIENTE + SE1->E1_LOJA, "A1_CGC"),;
			SE1->E1_NUM,;
			SE1->E1_PREFIXO})

		//Edison G. Barbieri
		//inicio 08/07/21
		//Adiciona dados para envio do boleto via e-mail. Tanto para impressŃo ou reimpressŃo
		aAdd(aDadosEnvi, {Upper(AllTrim(SubStr(Posicione("SA1",1, xFilial("SA1") + SE1->E1_CLIENTE + SE1->E1_LOJA, "A1_NOME"),01,30))),;
			Posicione("SA1",1, xFilial("SA1") + SE1->E1_CLIENTE + SE1->E1_LOJA, "A1_CGC"),;
			SE1->E1_NUM,;
			SE1->E1_PREFIXO,;
			SE1->E1_PARCELA})

		//Fim 08/07/21

		IF lfFatAuto
			//		oPrn := FWMSPrinter():New(cFileName, nDevice, , , lDisabeSetup, , , ,, , , lViewPDF,  )
			//		oPrn := FWMSPrinter():New(cNomePDF, IMP_PDF, lAdjustToLegacy,,lDisableSetup,,,,,,,.F.)
			oPrn:StartPage()
		ENDIF

		fImpPagina(lfFatAuto)

		IF lfFatAuto

			//| Abate o saldop do Range.

			U_FSFAT01F(SE1->(RECNO()),cpCodRg)

			oPrn:EndPage()

		ELSE

			//| Verifica se ķ diferente de 2║ Via quando nŃo for automßtico.

			IF mv_Par15 <> 1

				cpCodRg := U_FSFAT01G(cBanco,cAgencia,cConta,cSubCta)

				IF !EMPTY(cpCodRg)

					U_FSFAT01F(SE1->(RECNO()),cpCodRg)

				ENDIF

			ENDIF

		ENDIF

		//Edison G. Barbieri 08/07/21
		//Faz o envio do boleto ao cliente

		If !_auto
			if Len(aFiles) > 0 //.and. !cEmpAnt $ "02/03/10"

				U_MailCPX(aFiles,aDadosEnvi[01,01],aDadosEnvi[01,03],aDadosEnvi[01,04],aDadosEnvi[01,02],aDadosEnvi[01,05])
				aDadosEnvi := {}

			endIf
		endIf

		DBSELECTAREA("SE1")
		SE1->(dbSkip())

	EndDo

	//┌─────────────────────────────────────────────────────────────┐
	//│ Imprime direto na impressora ou Visualiza antes de imprimir │
	//└─────────────────────────────────────────────────────────────┘

	If !_auto

		/* Inicio Edison G. Barbieri 01/11/21
		if Len(aFiles) > 0 .and. cEmpAnt $ "02/03/10"
			cMsgInt := U_RJENVCDR(aFiles, .T.,,,aEmail)
			if !Empty(cMsgInt)
			Alert("Erros na integrańŃo: " + cMsgInt)
			endIf

		endIf
		Fim Edison G. Barbieri 01/11/21 */

		oPrn:Preview()
		/* GUSTAVO 06/03/2017
	Else

	lSend := Len(aFiles) > 0

		If lSend .and. (Len(aEmail) > 0)
   		U_MailCPX(aFiles,aEmail[01,01],aEmail[01,03],aEmail[01,04],aEmail[01,02])
		Endif
		*/
	Endif

Return .T.

//┌─────────────────────────────────────────ć┐
//│Controle de impressŃo das vias do boleto.│
//└─────────────────────────────────────────ć┘

Static Function fImpPagina(lfFatAuto)

	Local _nLinBase := 0
	Local lGeraPDF := GetNewPar("CN_CDRENT", .F.)
	Local lBolPDF  := GetNewPar("ED_ENVBOL", .F.)
	Local cFilePDF, cPathLoc, cTempPath
	Local _nLinBAt
	Local cSession     	:= GetPrinterSession()
	Default lfFatAuto	:= .F.

	Private oSetup := nil
	Private cDvCod  := ""

	//┌────────────────────────────────────────────`
	//│Fonte utilizadas para impressŃo dos boletos.│
	//└────────────────────────────────────────────`

	if !_auto

		oFont1 :=     TFont():New("Arial"      		,09,08,,.F.,,,,,.F.)           //** TĒtulo das Grades
		oFont2 :=     TFont():New("Arial"      		,09,09,,.F.,,,,,.F.)           //** Conte·do Campos
		oFont3Bold := TFont():New("Arial"			    ,09,15,,.T.,,,,,.F.)      //** Dados do Recibo de Entrega
		oFont4 := 	  TFont():New("Arial"      		,09,12,,.T.,,,,,.F.)          //** Codigo de CompensańŃo do Banco
		oFont5 := 	  TFont():New("Arial"      		,09,18,,.T.,,,,,.F.)          //** Codigo de CompensańŃo do Banco
		oFont6 := 	  TFont():New("Arial"      	  ,09,14,,.T.,,,,,.F.)            //** Conteudo dos Campos em Negrito
		oFont7 := 	  TFont():New("Arial"         ,09,10,,.T.,,,,,.F.)            //** Dados do Cliente
		oFont8 := 	  TFont():New("Arial"         ,09,09,,.F.,,,,,.F.)	          //** Conteudo Campos
		oFont9 := 	  TFont():New("Arial"         ,09,12,,.F.,,,,,.F.)            //** Linha Digitavel
		oFont18n   := TFont():New("Arial"         ,09,18,.T.,.T.,5,.T.,5,.T.,.F.) //** Para C¾digo do banco

	Else

		IF !lfFatAuto

			cNomePDF := "danfe_"+cEmpAnt + cFilAnt + Trim(SE1->E1_NUM) + Trim(SE1->E1_PREFIXO) + Trim(SE1->E1_PARCELA) //|+ ".rel"

			lAdjustToLegacy := .F. // Inibe legado de resoluńŃo com a TMSPrinter
			lDisableSetup   := .T.
			oPrn := FWMSPrinter():New(cNomePDF, IMP_PDF, lAdjustToLegacy,,lDisableSetup,@oSetup ,,,,,,.F.)

			nFlags := PD_ISTOTVSPRINTER + PD_DISABLEPAPERSIZE + PD_DISABLEPREVIEW + PD_DISABLEMARGIN

			oSetup := FWPrintSetup():New(nFlags, "DANFE")

			/*------------------------------------------------------
			ImpressŃo da DANFE
			--------------------------------------------------------*/

			DBSELECTAREA("SF2")
			DBSETORDER(1) //| F2_FILIAL, F2_DOC, F2_SERIE, F2_CLIENTE, F2_LOJA, F2_FORMUL, F2_TIPO, R_E_C_N_O_, D_E_L_E_T_
			SF2->(DBSEEK(SE1->(E1_FILIAL+E1_NUM + E1_PREFIXO + E1_CLIENTE + E1_LOJA)))

			cIdEnt := RetIdEnti()

			oPrn:LADJUSTTOLEGACY := .F.
			lIsLoja	:= .t.
			U_PrtNfeSef(cIdEnt, /*cVal1*/,/*cVal2*/	, @oPrn,	@oSetup, cNomePDF	, lIsLoja	)

			oPrn:EndPage()     // Finaliza a pßgina

			//|oPrn:LADJUSTTOLEGACY := .T.

			oPrn:StartPage()

			oPrn:SetResolution(78)
			oPrn:SetPortrait()
			oPrn:SetPaperSize(DMPAPER_A4)
			oPrn:SetMargin(00,00,00,00)
			oPrn:linjob   :=.F.

			oPrn:cPathPDF := CLOCPDF
			oPrn:SetDevice(IMP_PDF)
			oPrn:SetViewPDF(.F.)

		ENDIF

		//┌───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐
		//│Deixado diferenciada a criańŃo das fontes pra tratar impressŃo automßtica, mas para gerańŃo de pdf o sistema nŃo respeita as fontes setadas│
		//└───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘

		oFont1 :=     TFont():New("Arial"      		,09,08,,.F.,,,,,.F.)            //** TĒtulo das Grades
		oFont2 :=     TFont():New("Arial"      		,09,09,,.F.,,,,,.F.)            //** Conte·do Campos
		oFont3Bold := TFont():New("Arial"			    ,09,15,,.T.,,,,,.F.)            //** Dados do Recibo de Entrega
		oFont4 := 	  TFont():New("Arial"      		,09,12,,.T.,,,,,.F.)            //** Codigo de CompensańŃo do Banco
		oFont5 := 	  TFont():New("Arial"      		,09,18,,.T.,,,,,.F.)            //** Codigo de CompensańŃo do Banco
		oFont6 := 	  TFont():New("Arial"      	  ,09,14,,.T.,,,,,.F.)            //** Conteudo dos Campos em Negrito
		oFont7 := 	  TFont():New("Arial"         ,09,10,,.T.,,,,,.F.)            //** Dados do Cliente
		oFont8 := 	  TFont():New("Arial"         ,09,09,,.F.,,,,,.F.)	          //** Conteudo Campos
		oFont9 := 	  TFont():New("Arial"         ,09,12,,.F.,,,,,.F.)            //** Linha Digitavel
		oFont18n   := TFont():New("Arial"         ,09,18,.T.,.T.,5,.T.,5,.T.,.F.) //** Para C¾digo do banco

	EndIf

	// Faz o controle de gerańŃo de PDF dos boletos
	if lGeraPDF
		cTempPath := "\nfe\"
		cPathLoc := GetTempPath(.T.)

		cFilePDF := "bol_" + Trim(cEmpAnt) + Trim(SE1->E1_FILIAL) + Trim(SE1->E1_NUM) + Trim(SE1->E1_PARCELA) + ".rel"

		oPrnPDF := FWMSPrinter():New(cFilePDF, IMP_PDF, .F., , .T.)

		oPrnPDF:SetResolution(78)
		oPrnPDF:SetPortrait()
		oPrnPDF:SetPaperSize(DMPAPER_A4)
		oPrnPDF:SetMargin(00,00,00,00)
		oPrnPDF:linjob   :=.F.

		oPrnPDF:cPathPDF := cPathLoc
		oPrnPDF:SetDevice(IMP_PDF)
		oPrnPDF:SetViewPDF(.F.)
		//oDanfePDF:lServer := .F.

		//Edison G. Barbieri
		//Incio 03/07/2021
	elseif lBolPDF
		cTempPath := "\boletos\"
		cPathLoc := GetTempPath(.T.)

		cFilePDF := "bol_" + Trim(cEmpAnt) + Trim(SE1->E1_FILIAL) + Trim(SE1->E1_NUM) + Trim(SE1->E1_PARCELA) + ".rel"

		oPrnPDF := FWMSPrinter():New(cFilePDF, IMP_PDF, .F., , .T.)

		oPrnPDF:SetResolution(78)
		oPrnPDF:SetPortrait()
		oPrnPDF:SetPaperSize(DMPAPER_A4)
		oPrnPDF:SetMargin(00,00,00,00)
		oPrnPDF:linjob   :=.F.

		oPrnPDF:cPathPDF := cPathLoc
		oPrnPDF:SetDevice(IMP_PDF)
		oPrnPDF:SetViewPDF(.F.)
		//oDanfePDF:lServer := .F.
	endIf

	//fim 03/07/2021

	//┌──────────────────────────────────────────────────0
	//│Atribui o DĒgito do Codigo do Banco a uma Varißvel│
	//└──────────────────────────────────────────────────0

	cDvCod := fDvBco(aDadosBanco[01])

	//┌──────────────────────────┐
	//│Calcula o C¾digo de Barras│
	//└──────────────────────────┘

	M->CodBarras := fCodigoBarras(aDadosBanco[01])

	//┌──────────────────────────────────┐
	//│Montar a Linha Digitavel da Boleta│
	//└──────────────────────────────────┘

	M->LinhaDig := fLinhaDigitavel(aDadosBanco[01])

	//┌────────────────────────────────┐
	//│RECIBO DE ENTREGA (Terceira Via)│
	//└────────────────────────────────┘

	_nLinBase := 0
	if !_auto
		fImprimeVia( 3, _nLinBase, oPrn )
		// faz o controle para voltar a linha anterior
		if lGeraPDF
			//_nLinBAt := _nLinBase
			//_nLinBase := 0
			fImpPDF( 3, _nLinBase, oPrnPDF )
			//_nLinBase := _nLinBAt

			//Edison G. Barbieri
			//Incio 03/07/2021
		elseif lBolPDF

			fImpPDF( 3, _nLinBase, oPrnPDF )

		endIf
		//fim
	Else
		fImpPDF(3, _nLinBase, oPrn )
	EndIf

	//┌──────────────────────────────Ž
	//│RECIBO DO PAGADOR (Segunda Via)│
	//└──────────────────────────────Ž

	if !_auto
		_nLinBase := 1100
		fImprimeVia( 2, _nLinBase, oPrn )
		// faz o controle para voltar a linha anterior
		if lGeraPDF
			//_nLinBAt := _nLinBase
			//_nLinBase := 1100
			_nLinBase := (1100/4)
			fImpPDF( 2, _nLinBase, oPrnPDF )
			//_nLinBase := _nLinBAt

			//Edison G. Barbieri
			//Incio 03/07/2021
		elseif lBolPDF

			_nLinBase := (1100/4)
			fImpPDF( 2, _nLinBase, oPrnPDF )

		endIf
		//fim
	Else
		_nLinBase := (1100/4)
		fImpPDF(2, _nLinBase, oPrn )
	EndIf

	//┌───────────────────────────────────┐
	//│FICHA DE COMPENSAŪ├O (Primeira Via)│
	//└───────────────────────────────────┘

	if !_auto
		_nLinBase := 2200
		fImprimeVia( 1, _nLinBase, oPrn )
		// faz o controle para voltar a linha anterior
		if lGeraPDF
			//_nLinBAt := _nLinBase
			//_nLinBase := 2200
			_nLinBase := (2200/4)
			fImpPDF( 1, _nLinBase, oPrnPDF )
			//_nLinBase := _nLinBAt

			//Edison G. Barbieri
			//Incio 03/07/2021
		elseif lBolPDF

			_nLinBase := (2200/4)
			fImpPDF( 1, _nLinBase, oPrnPDF )

		endIf
		//fim
	Else
		_nLinBase := (2200/4)
		fImpPDF(1, _nLinBase, oPrn )
	EndIf

	//┌────────────────────┐
	//│ Finaliza a Pagina  │
	//└────────────────────┘

	if !_auto
		oPrn:EndPage()

		// Continuar
		if lGeraPDF
			oPrnPDF:Print()
			FreeObj(oPrnPDF)

			// copia o pdf gerado para o servidor
			cFilePDF := SubStr(cFilePDF, 1, Len(cFilePDF) - 4) + ".pdf"
			CpyT2S(cPathLoc + cFilePDF, cTempPath, .F.)

			aAdd(aFiles, {cTempPath + cFilePDF, ;
				Trim(cEmpAnt) + Trim(SE1->E1_FILIAL) + Trim(SE1->E1_NUM) + Trim(SE1->E1_PARCELA),;
				SE1->E1_NUM, SE1->E1_SERIE, SE1->E1_PARCELA, SE1->E1_PREFIXO, DToS(SF2->F2_EMISSAO), SE1->E1_FILIAL})

			//Edison G. Barbieri
			//Incio 03/07/2021
		elseif lBolPDF
			oPrnPDF:Print()
			FreeObj(oPrnPDF)

			// copia o pdf gerado para o servidor
			cFilePDF := SubStr(cFilePDF, 1, Len(cFilePDF) - 4) + ".pdf"
			CpyT2S(cPathLoc + cFilePDF, cTempPath, .F.)

			aAdd(aFiles, {cTempPath + cFilePDF, ;
				Trim(cEmpAnt) + Trim(SE1->E1_FILIAL) + Trim(SE1->E1_NUM) + Trim(SE1->E1_PARCELA),;
				SE1->E1_NUM, SE1->E1_SERIE, SE1->E1_PARCELA, SE1->E1_PREFIXO, DToS(SF2->F2_EMISSAO), SE1->E1_FILIAL})

		endIf
		//Fim


	Else

		IF !lfFatAuto
			oPrn:EndPage()
			oPrn:Print()

			//┌───────────────────────────────────────────────────────────────────────────────┐
			//│JEAN - 10/09/14 - VALIDA SE ARQUIVO EXISTE ANTES DE ADICIONAR └ VARI┴VEL AFILES│
			//└───────────────────────────────────────────────────────────────────────────────┘

			If ValType(cFilePDF) == "C"
				if File(cFilePDF)
					aAdd(aFiles, {cFilePDF})
				EndIf
			EndIf

			//┌───────────────────────────────────────────────────────────────────────────────┐
			//│JEAN - 10/09/14 - VALIDA SE ARQUIVO EXISTE ANTES DE ADICIONAR └ VARI┴VEL AFILES│
			//└───────────────────────────────────────────────────────────────────────────────┘

			//┌───────────────────────────────────────────────────────────────────────────────┐
			//│JEAN - 10/09/14 - VALIDA SE ARQUIVO EXISTE ANTES DE ADICIONAR └ VARI┴VEL AFILES│
			//└───────────────────────────────────────────────────────────────────────────────┘

			if File(oPrn:cPathPDF + cEmpAnt + cFilAnt + Trim(SE1->E1_NUM) + Trim(SE1->E1_PREFIXO) + Trim(SE1->E1_PARCELA) + ".pdf")
				If CpyT2S(oPrn:cPathPDF + cEmpAnt + cFilAnt + Trim(SE1->E1_NUM) + Trim(SE1->E1_PREFIXO) + Trim(SE1->E1_PARCELA) + ".pdf", CDIRSRV, .F.)
					aAdd(aFiles, {CDIRSRV + cEmpAnt + cFilAnt + Trim(SE1->E1_NUM) + Trim(SE1->E1_PREFIXO) + Trim(SE1->E1_PARCELA) + ".pdf"})
				EndIf
			EndIf

			FreeObj(oPrn)

		ELSE

			AADD(alRetTit,SE1->(RECNO()))

		ENDIF

	EndIf

Return Nil

//┌──────────────────────────────────────────────────────────┐
//│Imprime via do boleto de acordo com o parŌmetro informado.│
//└──────────────────────────────────────────────────────────┘

Static Function fImprimeVia( _nVia, _nL, oPrn )
	Local _nPapel  := 1
	Local _nLBarra := 0
	Local _nCol    := -70
	Local _nVaria  := 190

	//** TODOS **
	Do Case

		//┌─────────────┐
		//│Para Laser A4│
		//└─────────────┘

		Case _nPapel = 1
			_nL -= 85
			_nLBarra := 23.7

			//┌───────────────────────────────┐
			//│Para Laser Oficio 2 (216 x 330)│
			//└───────────────────────────────┘

		Case _nPapel = 2
			_nL += 50
			_nLBarra := 29.6
	EndCase

	oPrn:Line(_nL+80,690,_nL+150,690)  //** Linhas Verticais do Codigo
	oPrn:Line(_nL+80,900,_nL+150,900)  //** Ex:  | 001-9 |

	//┌────────────────────────────────────────────────────────────────────────────────\┐
	//│Valida se existe imagem de logo pra por no boleto, senŃo imprime o nome do banco│
	//└────────────────────────────────────────────────────────────────────────────────\┘

	if fValImage(aDadosBanco[01])
		oPrn:sayBitmap(_nL+080,30,"/system/"+aDadosBanco[01]+".bmp",350,78)
	Else
		oPrn:Say(_nL+090,0100,aDadosBanco[02],oFont3Bold,100)
	EndIf

	oprn:say(_nL+080,0710,fRetCodBco(aDadosBanco[01])+cDvCod,oFont18n)   			//** Codigo "001-9"

	oPrn:Box(_nL+160,_nCol+0100,_nL+240,_nCol+1500+_nVaria)         			//** Local de Pagamento
	oPrn:Box(_nL+160,_nCol+1500+_nVaria,_nL+240,_nCol+2200+_nVaria) 			//** Vencimento
	oprn:box(_nL+240,_nCol+0100,_nL+320,_nCol+1500+_nVaria)         			//** Beneficißrio
	oprn:box(_nL+240,_nCol+1500+_nVaria,_nL+320,_nCol+2200+_nVaria) 			//** Agencia / Codigo Beneficißrio
	oprn:box(_nL+320,_nCol+0100,_nL+400,_nCol+0380) 											//** Data Documento
	oprn:box(_nL+320,_nCol+0380,_nL+400,_nCol+0700) 											//** Nr Documento
	oprn:box(_nL+320,_nCol+0700,_nL+400,_nCol+0890) 											//** Especie Doc
	oprn:box(_nL+320,_nCol+0890,_nL+400,_nCol+1060)
	oprn:box(_nL+320,_nCol+1060,_nL+400,_nCol+1500+_nVaria)
	oprn:box(_nL+320,_nCol+1500+_nVaria,_nL+400,_nCol+2200+_nVaria)

	//┌─────────────────────────────────────────────────────────────
	//│Tratativa para o campo CIP (particularidade de alguns bancos)
	//└─────────────────────────────────────────────────────────────

	Do Case

		//┌────────┐
		//│BicBanco│
		//└────────┘

		Case aDadosBanco[01] == "320"
			oprn:box(_nL+400,_nCol+0100,_nL+480,_nCol+0350)         					//** Uso do Banco
			oprn:say(_nL+400,_nCol+0120,"Uso do Banco",oFont1,100)
			oprn:say(_nL+430,_nCol+0120,cCpoUsoBco(aDadosBanco[01]),oFont2,100)

			oprn:box(_nL+400,_nCol+0350,_nL+480,_nCol+0450) 									//** CIP
			oprn:say(_nL+400,_nCol+0370,"CIP",oFont1,100)
			oprn:say(_nL+430,_nCol+0370,"521",oFont2,100)

			oprn:box(_nL+400,_nCol+0450,_nL+480,_nCol+0650) 									//** Carteira
			oprn:say(_nL+400,_nCol+0470,"Carteira",oFont1,100)
			oprn:say(_nL+430,_nCol+0470,fCpoCart(aDadosBanco),oFont2,100)

			//┌──────────────────┐
			//│Banco Panamericano│
			//└──────────────────┘

		Case aDadosBanco[01] == "623"
			oprn:box(_nL+400,_nCol+0100,_nL+480,_nCol+0350)         					//** Uso do Banco
			oprn:say(_nL+400,_nCol+0120,"Uso do Banco",oFont1,100)
			oprn:say(_nL+430,_nCol+0120,cCpoUsoBco(aDadosBanco[01]),oFont2,100)

			oprn:box(_nL+400,_nCol+0350,_nL+480,_nCol+0450) 									//** CIP
			oprn:say(_nL+400,_nCol+0370,"CIP",oFont1,100)
			oprn:say(_nL+430,_nCol+0370,"000",oFont2,100)

			oprn:box(_nL+400,_nCol+0450,_nL+480,_nCol+0650) 									//** Carteira
			oprn:say(_nL+400,_nCol+0470,"Carteira",oFont1,100)
			oprn:say(_nL+430,_nCol+0470,fCpoCart(aDadosBanco),oFont2,100)

			//┌────────┐
			//│Daycoval│
			//└────────┘

		Case aDadosBanco[01] == "707"
			oprn:box(_nL+400,_nCol+0100,_nL+480,_nCol+0350)         					//** Uso do Banco
			oprn:say(_nL+400,_nCol+0120,"Uso do Banco",oFont1,100)
			oprn:say(_nL+430,_nCol+0120,cCpoUsoBco(aDadosBanco[01]),oFont2,100)

			oprn:box(_nL+400,_nCol+0350,_nL+480,_nCol+0450) 									//** CIP
			oprn:say(_nL+400,_nCol+0370,"CIP",oFont1,100)
			oprn:say(_nL+430,_nCol+0370,"504",oFont2,100)

			oprn:box(_nL+400,_nCol+0450,_nL+480,_nCol+0650) 									//** Carteira
			oprn:say(_nL+400,_nCol+0470,"Carteira",oFont1,100)
			oprn:say(_nL+430,_nCol+0470,fCpoCart(aDadosBanco),oFont2,100)

			//┌─────────┐
			//│Santander│
			//└─────────┘

		Case aDadosBanco[01] == "033"
			oprn:box(_nL+400,_nCol+0100,_nL+480,_nCol+0650) 									//** Carteira
			oprn:say(_nL+400,_nCol+0320,"Carteira",oFont1,100)
			oprn:say(_nL+430,_nCol+0120,fCpoCart(aDadosBanco),oFont2,100)

		OtherWise
			oprn:box(_nL+400,_nCol+0100,_nL+480,_nCol+0350)         					//** Uso do Banco
			oprn:say(_nL+400,_nCol+0120,"Uso do Banco",oFont1,100)
			oprn:say(_nL+430,_nCol+0120,cCpoUsoBco(aDadosBanco[01]),oFont2,100)

			oprn:box(_nL+400,_nCol+0350,_nL+480,_nCol+0650)      							//** Carteira
			oprn:say(_nL+400,_nCol+0400,"Carteira",oFont1,100)
			oprn:say(_nL+430,_nCol+0450,fCpoCart(aDadosBanco),oFont2,100)

	EndCase

	oprn:box(_nL+400,_nCol+0650,_nL+480,_nCol+0800)         							//** Espķcie
	oprn:box(_nL+400,_nCol+0800,_nL+480,_nCol+1210)         							//** Quantidade
	oprn:box(_nL+400,_nCol+1210,_nL+480,_nCol+1500+_nVaria) 							//** Valor
	oprn:box(_nL+400,_nCol+1500+_nVaria,_nL+480,_nCol+2200+_nVaria)
	oprn:box(_nL+480,_nCol+0100,_nL+0880,_nCol+2200+_nVaria)
	oprn:box(_nL+880,_nCol+0100,_nL+1020,_nCol+2200+_nVaria)
	oprn:box(_nL+1020,_nCol+0100,_nL+1055,_nCol+2200+_nVaria)

	If _nVia == 1 .or. _nVia == 2
		oprn:box(_nL+480,_nCol+1500+_nVaria,_nL+560,_nCol+2200+_nVaria)
		oprn:box(_nL+560,_nCol+1500+_nVaria,_nL+640,_nCol+2200+_nVaria)
		oprn:box(_nL+640,_nCol+1500+_nVaria,_nL+720,_nCol+2200+_nVaria)
		oprn:box(_nL+720,_nCol+1500+_nVaria,_nL+800,_nCol+2200+_nVaria)
		oprn:box(_nL+800,_nCol+1500+_nVaria,_nL+880,_nCol+2200+_nVaria)
	Endif

	oprn:say(_nL+160,_nCol+0120,"Local de Pagamento",oFont1,100)
	oprn:say(_nL+190,_nCol+0120,fRetLocPag(aDadosBanco[01]),oFont2,100)
	oprn:say(_nL+160,_nCol+1520+_nVaria,"Vencimento",oFont1,100)

	_cDataTmp := Substr(DtoS(SE1->E1_VENCTO),7,2) + "/" + ;
		Substr(DtoS(SE1->E1_VENCTO),5,2) + "/" + ;
		Substr(DtoS(SE1->E1_VENCTO),1,4)

	oprn:say(_nL+190,_nCol+2150+_nVaria,_cDataTmp,oFont7,,,,PAD_RIGHT)

	oprn:say(_nL+240,_nCol+0120,"Beneficißrio",oFont1,100)
	oprn:say(_nL+270,_nCol+0120,fRetCed(aDadosBanco[01]), oFont2,100)
	oprn:say(_nL+240,_nCol+1520+_nVaria,"AgĻncia / C¾digo Beneficißrio",oFont1,100)
	oprn:say(_nL+270,_nCol+2150+_nVaria,fAgeCodCed(aDadosBanco), oFont7,,,, PAD_RIGHT)

	oprn:say(_nL+320,_nCol+0120,"Data do Documento",oFont1)

	_cDataTmp := Substr(DtoS(SE1->E1_EMISSAO),7,2) + "/" + ;
		Substr(DtoS(SE1->E1_EMISSAO),5,2) + "/" + ;
		Substr(DtoS(SE1->E1_EMISSAO),1,4)

	oprn:say(_nL+350,_nCol+0120,_cDataTmp,oFont2,100)
	oprn:say(_nL+320,_nCol+0390,"N·mero do Documento",oFont1,100)
	oprn:say(_nL+350,_nCol+0400,fNroDoc(aDadosBanco[01]),oFont2,100)
	oprn:say(_nL+320,_nCol+0720,"Espķcie Doc",oFont1,100)
	oprn:say(_nL+350,_nCol+0720,fEspDoc(aDadosBanco[01]),oFont2,100)
	oprn:say(_nL+320,_nCol+0900,"Aceite",oFont1,100)
	oprn:say(_nL+350,_nCol+0910,fRetAce(aDadosBanco),oFont2,100)
	oprn:say(_nL+320,_nCol+1080,"Data Processamento",oFont1,100)

	_cDataTmp := Substr(DtoS(dDataBase),7,2) + "/" + ;
		Substr(DtoS(dDataBase),5,2) + "/" + ;
		Substr(DtoS(dDataBase),1,4)

	oprn:say(_nL+350,_nCol+1180,_cDataTmp,oFont2,100)

	oprn:say(_nL+320,_nCol+1520+_nVaria, fLbCpoNNro(aDadosBanco[01]),oFont1,PAD_RIGHT)
	oprn:say(_nL+350,_nCol+2150+_nVaria, fCpoNNro(M->NumBoleta, dvBol, aDadosBanco),oFont7,,,,PAD_RIGHT)

	oprn:say(_nL+400,_nCol+0670,fLbEsp(aDadosBanco[01]),oFont1,100)
	oprn:say(_nL+430,_nCol+0670,fEspecie(aDadosBanco[01]),oFont2,100)
	oprn:say(_nL+400,_nCol+0820,"Quantidade",oFont1,100)
	oprn:say(_nL+400,_nCol+1240,"Valor",oFont1,100)
	oprn:say(_nL+400,_nCol+1520+_nVaria,"(=) Valor do Documento",oFont1,100)
	oprn:say(_nL+430,_nCol+2143+_nVaria,Transform(nValLiq,"@E 999,999,999.99"),oFont7,,,,PAD_RIGHT)

	If _nVia == 1

		oprn:say(_nL+480,_nCol+0120,"Instruń§es (Todas as instruń§es desse bloqueto sŃo de exclusiva responsabilidade do cedente)",oFont1,100)
		oprn:say(_nL+480,_nCol+1520+_nVaria,"(-) Desconto",oFont1,100)
		oprn:say(_nL+560,_nCol+1520+_nVaria,"(-) Outras Deduń§es (abatimento)",oFont1,100)
		oprn:say(_nL+640,_nCol+1520+_nVaria,"(+) Mora / Multa (Juros)",oFont1,100)
		oprn:say(_nL+720,_nCol+1520+_nVaria,"(+) Outros Acrķscimos",oFont1,100)
		oprn:say(_nL+800,_nCol+1520+_nVaria,"(=) Valor Cobrado",oFont1,100)

		_nQtdLin := 0
		_nCtr    := 1
		_nQtdIni := 510
		for _nCtr := 1 to len(aMensagem)
			oprn:say(_nL+(_nQtdIni+_nQtdLin),0120, aMensagem[_nCtr], oFont2,100)
			_nQtdLin += 40
		Next _nCtr

		cTelCob := ""
		cTelCob := SuperGetMv("MV_TELCOB",,"("+SubStr(SM0->M0_TEL,4,2)+") "+SubStr(SM0->M0_TEL,7,8))
		if Empty(cTelCob)
			cTelCob := "("+SubStr(SM0->M0_TEL,4,2)+") "+SubStr(SM0->M0_TEL,7,8)
		EndIf

		If  cBanco == "237" .and. (AllTrim(cConta)) == '0014046'
			oprn:say(_nL+845,0120," Central de Cobranńa: 41-3083-6999/cobranca@adnfomento.com.br ",oFont1,100)

		elseif  cBanco == "237" .and. (AllTrim(cConta)) == '0003098'
			oprn:say(_nL+800,0120,"TITULO CEDIDO A SIFRA S/A",oFont1,100)
			oprn:say(_nL+845,0120,"DUVIDAS SOBRE COBRANŪA, LIGUE "+cTelCob,oFont1,100)

		elseif cBanco == "237" .and. (AllTrim(cConta)) == '0838500'
			oprn:say(_nL+845,0120," PROTESTAR EM 5 DIAS. D┌VIDAS TEL. (47)3355-9981 E-MAIL comercial@rnxfidc.com.br ",oFont1,100)

		elseif cBanco == "237" .and. (AllTrim(cConta)) == '0002364'
			oprn:say(_nL+845,0120,"TĒtulo cedido ao Creditise FIDC NP",oFont1,100)

		elseif cBanco == "341" .and. (AllTrim(cConta)) == '17737'
			oprn:say(_nL+845,0120,"Duplicata cedida a IB Sigma, sua ·nica proprietßria LegĒtima.",oFont1,100)

		else
			oprn:say(_nL+845,0120,"DUVIDAS SOBRE COBRANŪA, LIGUE "+cTelCob,oFont1,100)
		endif

	ElseIf _nVia == 2
		oprn:say(_nL+480,_nCol+1520+_nVaria,"(-) Desconto",oFont1,100)
		oprn:say(_nL+560,_nCol+1520+_nVaria,"(-) Outras Deduń§es (abatimento)",oFont1,100)
		oprn:say(_nL+640,_nCol+1520+_nVaria,"(+) Mora / Multa (Juros)",oFont1,100)
		oprn:say(_nL+720,_nCol+1520+_nVaria,"(+) Outros Acrķscimos",oFont1,100)
		oprn:say(_nL+800,_nCol+1520+_nVaria,"(=) Valor Cobrado",oFont1,100)

		//┌─────────────────────────┐
		//│Particularidade Caixa    │
		//└─────────────────────────┘

		if aDadosBanco[01] == "104"
			oprn:say(_nL+1057,0050,"SAC CAIXA 0800 726 0101 (informań§es, reclamań§es, sugest§es e elogios)",oFont1,100)
			oprn:say(_nL+1083,0050,"Para pessoas com deficiĻncia auditiva ou de fala: 08007262492",oFont1,100)
			oprn:say(_nL+1113,0050,"Ouvidoria: 0800 725 7474 ",oFont1,100)
		EndIf

		//┌─────────────────────────┐
		//│Particularidade BIC Banco│
		//└─────────────────────────┘

		if aDadosBanco[01] == "320"
			oprn:say(_nL+480,_nCol+0120,"Instruń§es (Todas as instruń§es desse bloqueto sŃo de exclusiva responsabilidade do cedente)",oFont1,100)
		Else
			oprn:say(_nL+480,_nCol+0120,"Dados do Beneficißrio",oFont1,100)
		EndIf

		//┌────────────────────────────────────────4┐
		//│Particularidade de Mensagem do BIC Banco│
		//└────────────────────────────────────────4┘

		if aDadosBanco[01] == "320"
			_nQtdLin := 0
			_nCtr    := 1
			_nQtdIni := 510
			for _nCtr := 1 to len(aMensagem)
				oprn:say(_nL+(_nQtdIni+_nQtdLin),0120, aMensagem[_nCtr], oFont2,100)
				_nQtdLin += 40
			Next _nCtr

			//┌────────────────────────────────────────4┐
			//│Particularidade de Mensagem dos FIDC Banco 237│
			//└────────────────────────────────────────4┘

		elseif aDadosBanco[01] == "237" .and. (AllTrim(cConta)) == '0014046'

			oprn:say(_nL+590,0120,"  ", oFont2,100)

		elseif aDadosBanco[01] == "237" .and. (AllTrim(cConta)) == '0195660'

			oprn:say(_nL+590,0120,"  ", oFont2,100)

		elseif aDadosBanco[01] == "237" .and. (AllTrim(cConta)) == '0838500'

			oprn:say(_nL+590,0120,"  ", oFont2,100)



			//┌──────────────────────────── ┐
			//│Particularidade do Bic Safra│
			//└──────────────────────────── ┘
		ElseIf aDadosBanco[01] == "422"
			//oprn:say(_nL+510,0120,"Este boleto representa duplicata cedida fiduciariamente ao banco Safra S/A,  ", oFont2,100)
			//oprn:say(_nL+545,0120,"ficando vedado o pagamento de qualquer outra forma que nŃo atravķs do presente boleto.", oFont2,100)
			oprn:say(_nL+510,0120, Upper(Trim(SM0->M0_NOMECOM)) + " CNPJ: "+ Transform(SM0->M0_CGC,"@R 99.999.999/9999-99"), oFont2,100)
			oprn:say(_nL+545,0120, Upper(Trim(SM0->M0_ENDENT)), oFont2, 100)
			oprn:say(_nL+630,0120, SubStr(SM0->M0_CEPENT,01,02) +"."+ SubStr(SM0->M0_CEPENT,03,03) +"-"+ SubStr(SM0->M0_CEPENT,06,03) +;
				" "+ Upper(Trim(SM0->M0_CIDENT)) + " " + SM0->M0_ESTENT, oFont2, 100)

		Else
			oprn:say(_nL+590,0120, Upper(Trim(SM0->M0_NOMECOM)) + " CNPJ: "+ Transform(SM0->M0_CGC,"@R 99.999.999/9999-99"), oFont2,100)
			oprn:say(_nL+630,0120, Upper(Trim(SM0->M0_ENDENT)), oFont2, 100)
			oprn:say(_nL+670,0120, SubStr(SM0->M0_CEPENT,01,02) +"."+ SubStr(SM0->M0_CEPENT,03,03) +"-"+ SubStr(SM0->M0_CEPENT,06,03) +;
				" "+ Upper(Trim(SM0->M0_CIDENT)) + " " + SM0->M0_ESTENT, oFont2, 100)
		EndIf

		cTelCob := ""
		cTelCob := SuperGetMv("MV_TELCOB",,"("+SubStr(SM0->M0_TEL,4,2)+") "+SubStr(SM0->M0_TEL,7,8))
		if Empty(cTelCob)
			cTelCob := "("+SubStr(SM0->M0_TEL,4,2)+") "+SubStr(SM0->M0_TEL,7,8)
		EndIf

		If  cBanco == "237" .and. (AllTrim(cConta)) == '0014046'
			oprn:say(_nL+590,0120," Central de Cobranńa: 41-3083-6999/cobranca@adnfomento.com.br ",oFont1,100)

		elseif cBanco == "237" .and. (AllTrim(cConta)) == '0838500'
			oprn:say(_nL+590,0120," PROTESTAR EM 5 DIAS. D┌VIDAS TEL. (47)3355-9981 E-MAIL comercial@rnxfidc.com.br ",oFont1,100)

		elseif cBanco == "341" .and. (AllTrim(cConta)) == '17737'
			oprn:say(_nL+590,0120," ",oFont1,100)

		else
			oprn:say(_nL+710,0120,"DUVIDAS SOBRE COBRANŪA, LIGUE "+cTelCob,oFont1,100)
		endif

	Else
		oPrn:Say(_nL+790,0150," ASS.: " + Replicate(". ",90) + Space(04) + "DATA: " + Replicate(". ",05) + "/" +;
			Replicate(". ", 05,) + "/" + Replicate(". ", 10),oFont1,100)
	Endif

	oprn:say(_nL+880,_nCol+0120,"Pagador:",oFont1,100)
	oprn:say(_nL+900,_nCol+0250,SA1->A1_NOME,oFont8,100)

	If !Empty(SA1->A1_CEPC)
		oprn:say(_nL+940,_nCol+0250,SA1->A1_ENDCOB+" "+SA1->A1_BAIRROC,oFont8,100)
		oprn:say(_nL+980,_nCol+0250,"CEP " + SA1->A1_CEPC +" "+ SA1->A1_MUNC +" "+ SA1->A1_ESTC, oFont8,100)
	Else
		oprn:say(_nL+940,_nCol+0250,SA1->A1_END+" "+SA1->A1_BAIRRO,oFont8,100)
		oprn:say(_nL+980,_nCol+0250,"CEP " + SA1->A1_CEP +" "+ SA1->A1_MUN+" "+SA1->A1_EST,oFont8,100)
	Endif

	If SA1->A1_PESSOA == "J"
		oprn:say(_nL+900,_nCol+1500,Transform(SA1->A1_CGC,"@R 99.999.999/9999-99"),oFont8,100)
	ElseIf SA1->A1_PESSOA == "F"
		oprn:say(_nL+900,_nCol+1500,Transform(SA1->A1_CGC,"@R 999.999.999-99"),oFont8,100)
	Endif

	oprn:say(_nL+1020,_nCol+0120,"Sacador / Avalista",oFont1,100)
	oprn:say(_nL+1020,_nCol+0390,fSacAva(aDadosBanco[01]),oFont1,100)
	oprn:say(_nL+1020,_nCol+1520+_nVaria,"C¾digo de Baixa:",oFont1,100)
	oprn:say(_nL+1060,_nCol+1400+_nVaria,"AutenticańŃo MecŌnica",oFont1,100)

	Do Case
		Case _nVia == 1
			oprn:say(_nL+50,_nCol+0010,Replicate("- ",900),oFont1,100)
			oprn:say(_nL+1060,_nCol+2200+_nVaria,"Ficha de CompensańŃo",oFont4,,,, 1)

			//┌────────────────────────────┐
			//│ Imprime a Linha Digitavel  │
			//└────────────────────────────┘
			oPrn:Say(_nL+100,_nCol+2200+_nVaria, M->LinhaDig ,oFont9,,,, 1)

			//┌────────────────────────────┐
			//│ Imprime o Codigo de Barras │
			//└────────────────────────────┘

			MSBAR3("INT25", _nLBarra + 3.5, 0.5 ,M->CodBarras ,oPrn,.F.,NIL,NIL,0.025,1.5,NIL,NIL,"A",.F.)

		Case _nVia == 2
			oprn:say(_nL+50,0010,replicate("- ",900),oFont1,100)
			oPrn:Say(_nL+100,_nCol+2200+_nVaria,"Recibo do Pagador",oFont4,,,,PAD_RIGHT)

		Case _nVia == 3
			oprn:say(_nL+1060,_nCol+2200+_nVaria,"Controle do Beneficißrio",oFont4,,,,PAD_RIGHT)

			//┌────────────────────────────┐
			//│ Imprime a Linha Digitavel  │
			//└────────────────────────────┘
			oPrn:Say(_nL+100,_nCol+2200+_nVaria, M->LinhaDig ,oFont9,,,, 1)
	EndCase
Return

//┌──────────────────────────────────────────────────────────────────────┐
//│ Codigo de Barras - Calculo do Codigo de Barras do Boleto             │
//│ - Retorno: Caracter, 44                                              │
//└──────────────────────────────────────────────────────────────────────┘

Static Function fCodigoBarras(cBanco)
	Local _cBarra   := ""
	Local _cResult  := ""
	Local cNroBanco := ""
	Local cBarDV    := ""
	Local nDescfin  := 0
	Local nDecrecs  := 0
	Local nSaldo    := 0
	Private cBco    := cBanco

	if SE1->E1_VENCTO > Ctod("21/02/2025") 

		M->FatorVcto := StrZero( SE1->E1_VENCTO - Ctod("29/05/2022"), 04)

	else
		M->FatorVcto := StrZero( SE1->E1_VENCTO - Ctod("07/10/1997"), 04)		
	endif

	

	//Edison
	//banco sicoob considera outra data para o fator vencimento
	M->FatVtoSic := StrZero( SE1->E1_VENCTO - Ctod("03/07/2000") + 1000, 04)

	Do Case

		//┌─────────────────┐
		//│Banco do Nordeste│
		//└─────────────────┘

		Case cBanco == "004"
			_cBarra := "004"  + "9" + M->FatorVcto
			_cBarra += StrZero(nValLiq*100,10)
			_cBarra += aDadosBanco[03] + AllTrim(StrZero(Val(aDadosBanco[09]),8)) + Trim(M->NumBoleta) + Trim(dvBol) + aDadosBanco[8] + "000"

			//┌───────────────
			//│Banco do Brasil
			//└───────────────

		Case cBanco == "001"
			lConv7 := .F.
			lConv7 := Len(aDadosBanco[09]) == 7
			If lConv7
				_cBarra := "001"  + "9" + M->FatorVcto
				_cBarra += StrZero(nValLiq*100,10)
				_cBarra += "000000" + Trim(M->NumBoleta) + SubStr(aDadosBanco[08],01,02)
			Else
				_cBarra := "001"  + "9" + M->FatorVcto
				_cBarra += StrZero(nValLiq*100,10)
				_cBarra += Trim(M->NumBoleta) + aDadosBanco[03] + aDadosBanco[05] + SubStr(aDadosBanco[08],01,02)
			EndIf

			//┌─────────┐
			//│Santander│
			//└─────────┘

		Case cBanco == "033"
			cTpMod := "101"
			_cBarra := "033"  + "9" + M->FatorVcto
			_cBarra += StrZero(nValLiq*100,10) + "9"
			_cBarra += aDadosBanco[09] + Trim(M->NumBoleta) + Trim(dvBol) + "0" + cTpMod

			//┌───────────────────────┐
			//│Caixa Econ¶mica Federal│
			//└───────────────────────┘

		Case cBanco == "104"
			lSIGCB := Len(aDadosBanco[09]) == 7

			if lSIGCB

				cBarDV += aDadosBanco[09] + SuBStr(M->NumBoleta, 03, 03) + SuBStr(M->NumBoleta, 01, 01) + SuBStr(M->NumBoleta, 06, 03)
				cBarDV += SuBStr(M->NumBoleta, 02, 01) + SuBStr(M->NumBoleta, 09, 09)

				_cBarra := "104"  + "9" + M->FatorVcto
				_cBarra += StrZero(nValLiq*100,10)
				_cBarra += aDadosBanco[09] + SuBStr(M->NumBoleta, 03, 03) + SuBStr(M->NumBoleta, 01, 01) + SuBStr(M->NumBoleta, 06, 03)
				_cBarra += SuBStr(M->NumBoleta, 02, 01) + SuBStr(M->NumBoleta, 09, 09)
				_cBarra += fDvCpoLv(cBarDV)

			Else
				_cBarra := "104"  + "9" + M->FatorVcto
				_cBarra += StrZero(nValLiq*100,10)
				_cBarra += Trim(M->NumBoleta) + aDadosBanco[03] + SubStr(aDadosBanco[09],01,11)
			EndIf

			//┌────────┐
			//│Cresol│
			//└────────┘

		Case cBanco == "133"

			cAgeCor := ""
			cAgeCor := SubStr(aDadosBanco[11], 01, 04)
			cCtaCor := ""
			cCtaCor := "00" + SubStr(aDadosBanco[12], 01, 05)

			_cBarra := "133"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += cAgeCor + aDadosBanco[08] + Trim(M->Numboleta) + cCtaCor + "0"

			//┌───────────┐
			//│Banco Fibra│
			//└───────────┘

		Case cBanco == "224"
			cAgeCor := ""
			cAgeCor := SubStr(aDadosBanco[11], 01, 04)
			cCtaCor := ""
			cCtaCor := SubStr(aDadosBanco[12], 01, 05) + SubStr(aDadosBanco[12], 07, 01)

			_cBarra := "341"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += aDadosBanco[08] + Trim(M->Numboleta) + Trim(dvBol) + cAgeCor + cCtaCor + "000"

			//┌────────┐
			//│Bradesco│
			//└────────┘

		Case cBanco == "237"
			_cBarra := "237"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += aDadosBanco[03] + StrZero(Val(aDadosBanco[08]),2) + M->Numboleta + aDadosBanco[05] + "0"

			//┌────────┐
			//│UNAVANTI│
			//└────────┘

		Case cBanco == "460"
			//Edison G. Barbieri inicio 29/09/23
			
			//nDecrecs := SE1->E1_SDDECRE					
			//nDescfin := e1_valor * e1_descfin / 100
			nSaldo	 := SE1->E1_SALDO 					
			//Edison G. Barbieri inicio 29/09/23
			_cBarra := "460"  + "9" + M->FatorVcto
			_cBarra += StrZero(nSaldo*100,10)
			_cBarra += aDadosBanco[03] + StrZero(Val(aDadosBanco[08]),2) + M->Numboleta + StrZero(Val(aDadosBanco[09]),7) + "0"

			//┌─────────┐
			//│Banco ABC│
			//└─────────┘

		Case cBanco == "246"

			_cBarra := "246"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += SubStr(aDadosBanco[03], 01, 04) + aDadosBanco[08] + "5036216" + Trim(M->Numboleta) + Trim(dvBol)

			//┌─────────┐
			//│Bic Banco│
			//└─────────┘

		Case cBanco == "320"
			cAgeCor := ""
			cAgeCor := SubStr(aDadosBanco[11], 01, 04)
			cCtaCor := ""
			cCtaCor := StrZero(Val(SubStr(aDadosBanco[12], 01, At("-",aDadosbanco[12])-1)),07)

			_cBarra := "237"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += cAgeCor + aDadosBanco[08] + Trim(aDadosBanco[09]) + Trim(M->Numboleta) + cCtaCor + "0"

			//┌──────────┐
			//│Banco Ita·│
			//└──────────┘

		Case cBanco == "341"
			_cBarra := "341"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += aDadosBanco[08] + Trim(M->Numboleta) + Trim(dvBol) + aDadosBanco[03] + aDadosBanco[05] +;
				Mod10Itau(aDadosBanco[03] + aDadosBanco[05]) + "000"

			//┌────┐
			//│HSBC│
			//└────┘

		Case cBanco == "399"
			_cBarra := "399"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += Trim(M->Numboleta) + Trim(dvBol) + aDadosBanco[03] + aDadosBanco[05] + "00" + "1"

			//┌───────────┐
			//│Banco Safra│
			//└───────────┘

		Case cBanco == "422"

			// Inicio 17/12/21 Edison G. Barbieri
			//Ajuste devido a agencia ja ter movimentado no pagar e nao pode ser alterado movimentos no financeiro
			if (AllTrim(cConta)) == '00580030'
				_cBarra := "422"  + "9" + M->FatorVcto
				_cBarra += StrZero(SE1->E1_SALDO*100,10)
				_cBarra += "7" + aDadosBanco[11] + aDadosBanco[04] + aDadosBanco[05] + aDadosBanco[06] +;
					Trim(M->Numboleta) + "2"
			else
				_cBarra := "422"  + "9" + M->FatorVcto
				_cBarra += StrZero(SE1->E1_SALDO*100,10)
				_cBarra += "7" + aDadosBanco[03] + aDadosBanco[04] + aDadosBanco[05] + aDadosBanco[06] +;
					Trim(M->Numboleta) + "2"
			Endif
			// fim 17/12/21 Edison G. Barbieri

			//┌───────────┐
			//│Banco ID
			//└───────────┘

		Case cBanco == "439"
			_cBarra := "439"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += aDadosBanco[03] + StrZero(Val(aDadosBanco[08]),2) + M->Numboleta + "00" + aDadosBanco[05] + "0"
		
			//┌─────────┐
			//│Banco Luso cod│
			//└─────────┘

		Case cBanco == "600"
			cAgeCor := ""
			cAgeCor := SubStr(aDadosBanco[11], 01, 04)
			cCtaCor := ""
			cCtaCor := SubStr(aDadosBanco[12], 01, 07)

			_cBarra := "237"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += cAgeCor + aDadosBanco[08] + Trim(M->Numboleta) + cCtaCor + "0"

			//┌──────────────────┐
			//│Banco Panamericano│
			//└──────────────────┘

		Case cBanco == "623"
			cAgeCor := ""
			cAgeCor := SubStr(aDadosBanco[11], 01, 04)
			cCtaCor := ""
			cCtaCor := StrZero(Val(SubStr(aDadosBanco[12], 01, At("-",aDadosbanco[12])-1)),07)

			_cBarra := "237"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += cAgeCor + aDadosBanco[08] + Trim(M->Numboleta) + cCtaCor + "0"

			//┌────────────────Ķ
			//│Banco Votorantim│
			//└────────────────Ķ

		Case cBanco == "655"
			_cBarra := "655"  + "9" + M->FatorVcto
			_cBarra += StrZero(nValLiq*100,10) + aDadosBanco[09]
			_cBarra += "500" + Trim(M->Numboleta) + Trim(dvBol) + "00"

			//┌────────┐
			//│Daycoval│
			//└────────┘

		Case cBanco == "707"
			cAgeCor := ""
			cAgeCor := SubStr(aDadosBanco[11], 01, 04)
			cCtaCor := ""
			cCtaCor := SubStr(aDadosBanco[12], 01, 05) + SubStr(aDadosBanco[12], 07, 01)

			_cBarra := "341"  + "9" + M->FatorVcto
			_cBarra += StrZero(SE1->E1_SALDO*100,10)
			_cBarra += aDadosBanco[08] + Trim(M->Numboleta) + Trim(dvBol) + cAgeCor + cCtaCor + "000"

			//┌────────┐
			//│Citibank│
			//└────────┘

		Case cBanco == "745"
			_cBarra := "745" + "9" + M->FatorVcto
			_cBarra += StrZero(nValLiq*100,10)
			_cBarra += "3" + aDadosBanco[08] + SubStr(aDadosBanco[10],2,9) + M->Numboleta + dvBol

			//┌────────┐
			//│Sicredi│
			//└────────┘

		Case cBanco == "748"

			cBarDV += "1" + aDadosBanco[08] + SuBStr(M->NumBoleta, 01, 08) + dvBol + AllTrim(ADadosBanco[03]) + left(ADadosBanco[09],2)
			cBarDV += right(ADadosBanco[09],5) + "1" + "0"

			_cBarra := "748"  + "9" + M->FatorVcto
			_cBarra += StrZero(nValLiq*100,10)
			_cBarra += "1" + aDadosBanco[08] + SuBStr(M->NumBoleta, 01, 08) + dvBol + AllTrim(ADadosBanco[03]) + left(ADadosBanco[09],2)
			_cBarra += right(ADadosBanco[09],5) + "1" + "0"
			_cBarra += fDvCpoLv(cBarDV)

			//┌────────┐
			//│Sicoob│
			//└────────┘

		Case cBanco == "756"

			_cBarra := "756"  + "9" + M->FatVtoSic
			_cBarra += StrZero(nValLiq*100,10)
			_cBarra += aDadosBanco[08] + AllTrim(ADadosBanco[03]) + "01" + "0" + aDadosBanco[09] + SuBStr(M->NumBoleta, 01, 07) + dvBol

			if  Empty (SE1->E1_PARCELA)
				_cBarra += "001"

			else
				_cBarra += SE1->E1_PARCELA
			endif

	EndCase

	//┌─────────────────────────────────────────────
	//│Insere DĒgito Verificador no C¾digo de Barras
	//└─────────────────────────────────────────────

	_cResult := Substr(_cBarra,1,4)+;
		BarraDV(_cBarra)+;
		Substr(_cBarra,5,100)

Return(_cResult)

//┌───────────────────────────────────────────────────────────────────────┐
//│Cßlculo do dĒgito verificador do campo livre                           │
//└───────────────────────────────────────────────────────────────────────┘

Static Function fDvCpoLv(cBarDV)

	Local cRet  	:= ""
	Local Resto 	:= ""
	Local nCont 	:= 0
	Local nPeso 	:= 2
	local i     	:= 0
	local nCalc1    := 0
	local nCalc2    := 0
	local nCalc3    := 0

	Do case
		//┌────────────────────────┐
		//│Caixa Economica federal│
		//└────────────────────────┘
		Case cBanco == "104"

			For i := len(cBarDV) to 1 step -1
				nCont += Val(SubStr(cBarDV, i, 01)) * nPeso
				nPeso++
				if nPeso > 9
					nPeso := 2
				EndIf
			Next i

			if nCont < 11
				cRet   := AllTrim(Str(11 - nCont))
			Else
				Resto  := nCont % 11
				cRet   := AllTrim(Str(11 - Resto))

				if (11 - Resto) > 9
					cRet := "0"
				EndIf
			Endif

			//┌────────────────────────┐
			//│       Sicredi          │
			//└────────────────────────┘

		Case cBanco == "748"
			For i := len(cBarDV) to 1 step -1
				nCont += Val(SubStr(cBarDV, i, 01)) * nPeso
				nPeso++
				if nPeso > 9
					nPeso := 2
				EndIf
			Next i

			nCalc1  := nCont/11
			nCalc2  := int(nCalc1) * 11
			nCalc3  := nCont - nCalc2
			nCalc4  := 11 - nCalc3

			Iif(nCalc3 <= 1, cRet := "0", cRet := alltrim(Str(nCalc4)))

	EndCase

Return cRet

//┌──────────────────────────────────────────────────────────────────────┐
//│ Codigo de Barras - Calculo do Digito Verificador geral               │
//│ - Retorno: Caracter,1 -> Digito Verificador calculado                │
//└──────────────────────────────────────────────────────────────────────┘

Static Function BarraDV(_cBarCampo)

	Local i     := 0
	Local nCont := 0
	Local cPeso := 0
	Local Resto := 0
	Local Result := 0
	Local DV_BAR := Space(1)
	Local lConv7 := .F.

	Do Case

		//┌─────────────────┐
		//│Banco do Nordeste│
		//└─────────────────┘

		Case cBco == "004"
			nCont := 0
			cPeso := 2
			For i := 43 To 1 Step -1
				nCont += Val( SUBSTR( _cBarCampo,i,1 )) * cPeso
				cPeso++
				If cPeso >  9
					cPeso := 2
				Endif
			Next
			Resto  := nCont % 11
			Result := 11 - Resto
			Do Case
				Case Resto == 10 .or. Resto == 0 .or. Resto == 1
					DV_BAR := "1"
				OtherWise
					DV_BAR := Str(Result,1)
			EndCase

			//┌───────────────┐
			//│Banco do Brasil│
			//└───────────────┘

		Case cBco == "001"
			cFator := "4329876543298765432987654329876543298765432"
			nVal1  := 0
			nResult:= 0
			For I:=1 to Len(_cBarCampo)
				nResult := Val(Substr(_cBarCampo,I,1)) * Val(Substr(cFator,I,1))
				nVal1   += nResult
			Next

			nResto := nVal1 % 11
			nResto := 11 - nResto
			If nResto == 10
				nDig := 1
			ElseIf nResto == 11
				nDig := 1
			Else
				nDig := nResto
			EndIf
			DV_BAR := AllTrim(Str(nDig))

