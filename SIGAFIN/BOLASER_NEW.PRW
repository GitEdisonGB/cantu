		Case cBco == "399"
			i      := 0
			nCont  := 0
			nPeso  := 2
			nTmp   := 0
			nResto := 0

			For i := Len(_cCampo) to 1 step -1
				nTmp  := Val(SubStr(_cCampo, i, 1)) * nPeso
				nCont += iif(nTmp > 9, Val(SubStr(AllTrim(Str(nTmp)),1,1)) + Val(SubStr(AllTrim(Str(nTmp)),2,1)),nTmp)

				nPeso--

				If nPeso == 0
					nPeso := 2
				EndIf

			Next i

			nResto := nCont % 10

			Do Case
				Case nCont < 10
					_cResult := AllTrim(Str(10 - nCont))
				Case nResto == 0
