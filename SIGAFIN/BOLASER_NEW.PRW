Return cRet

//┌────────────────────────────────────────┐
//│Retorna o conte·do do campo Nosso N·mero│
//└────────────────────────────────────────┘

Static Function fCpoNNro(cBoleto, cDv, aDadosBanco)
	Local cRet := ""

	Do Case

		//┌─────────────────┐
		//│Banco do Nordeste│
		//└─────────────────┘

	Case aDadosBanco[01] == "004"
		cRet := Trim(cBoleto) + "-" + Trim(cDv) + "  " + Trim(AdadosBanco[8])

		//┌───────────────
		//│Banco do Brasil
		//└───────────────

	Case aDadosBanco[01] == "001"
		lConv7 := .F.
		lConv7 := Len(aDadosBanco[09]) == 7
		if lConv7
			cRet := Trim(cBoleto) + Trim(cDv)
		Else
			cRet := Trim(cBoleto) + "-" + Trim(cDv)
		EndIf

		//┌─────────┐
		//│Santander│
		//└─────────┘

	Case aDadosBanco[01] == "033"
		cRet := Trim(cBoleto) + " " + Trim(cDv)

		//┌───────────────────────┐
		//│Caixa Econ¶mica Federal│
		//└───────────────────────┘

	Case aDadosBanco[01] == "104"
		cRet := Trim(cBoleto) + "-" + Trim(cDv)

		//┌────┐
		//│Cresol│
		//└────┘

	Case aDadosBanco[01] == "133"
		cRet := aDadosBanco[08] + " / " + Trim(cBoleto) + "-" +	Trim(cDv)

		//┌───────────┐
		//│Banco Fibra│
		//└───────────┘

	Case aDadosBanco[01] == "224"
		cRet := aDadosBanco[08] + " / "	+ Trim(cBoleto) + "-" + Trim(cDv)

		//┌────────┐
		//│Bradesco│
		//└────────┘

	Case aDadosBanco[01] == "237"
		cRet := aDadosBanco[08] + " / " + Trim(cBoleto) + "-" +	Trim(cDv)

		//┌────────┐
		//│UNAVANTI│
		//└────────┘

	Case aDadosBanco[01] == "460"
		cRet := aDadosBanco[08] + " / " + Trim(cBoleto) + "-" +	Trim(cDv)

		//┌─────────┐
		//│Banco ABC│
		//└─────────┘

	Case aDadosBanco[01] == "246"
		cRet := aDadosBanco[03] + " / " + aDadosBanco[08] + " / " + Trim(cBoleto) + "-" + Trim(cDv)

		//┌─────────┐
		//│Bic Banco│
		//└─────────┘

	Case aDadosBanco[01] == "320"
		nCont   := 0
		cPeso   := 2
		cDig    := ""
		nBoleta := aDadosBanco[08] + aDadosBanco[09] + SubStr(cBoleto,01,06)
		For i := len(nBoleta) To 1 Step -1
			nCont := nCont + (Val(SubStr(nBoleta,i,1))) * cPeso
			cPeso := cPeso + 1
			If cPeso == 8
				cPeso := 2
			Endif
		Next

		Resto := ( nCont % 11 )

		Do Case
		Case Resto == 0
			cDig := "0"
		Case Resto == 1
			cDig := "P"
		OtherWise
			Resto   := ( 11 - Resto )
			cDig := AllTrim(Str(Resto))
		EndCase

		cRet := aDadosBanco[08] + " / " + aDadosBanco[09] +	Trim(cBoleto) + "-" +	Trim(cDig)

		//┌────┐
		//│Ita·│
		//└────┘

	Case aDadosBanco[01] == "341"
		cRet := aDadosBanco[08] + " / " + Trim(cBoleto) + "-" +	Trim(cDv)

		//┌────┐
		//│HSBC│
		//└────┘

	Case aDadosBanco[01] == "399"
		cRet := SubStr(Trim(cBoleto), 01, 02) + " " +;
			SubStr(Trim(cBoleto), 03, 03) + " " +;
			SubStr(Trim(cBoleto), 06, 03) + " " +;
			SubStr(Trim(cBoleto), 09, 02) + " " + cDv

		//┌───────────┐
		//│Banco Safra│
		//└───────────┘

	Case aDadosBanco[01] == "422"
		cRet :=  Trim(cBoleto)

		//┌───────────┐
		//│Banco ID│
		//└───────────┘

	Case aDadosBanco[01] == "439"
		cRet := "0" + aDadosBanco[08] + " / " + Trim(cBoleto) + "-" + Trim(cDv)

		//┌─────────┐
		//│Banco Luso│
		//└─────────┘

	Case aDadosBanco[01] == "600"
		cRet := aDadosBanco[08] + " / " + Trim(cBoleto) + "-" + Trim(cDv)

		//┌──────────────────?
		//│Banco Panamericano│
		//└──────────────────?

	Case aDadosBanco[01] == "623"
		cRet := aDadosBanco[08] + " / " + Trim(cBoleto) + "-" +	Trim(cDv)

		//┌────────────────Ó
		//│Banco Votorantim│
		//└────────────────Ó

	Case aDadosBanco[01] == "655"
		cRet := Trim(cBoleto) + Trim(cDv)

		//┌────────┐
		//│Daycoval│
		//└────────┘

	Case aDadosBanco[01] == "707"
		cRet := aDadosBanco[08] + " / " +	Trim(cBoleto) + "-" + Trim(cDv)

		//┌────────┐
		//│Citibank│
		//└────────┘

	Case aDadosBanco[01] == "745"
		cRet := Trim(cBoleto) + "-" + Trim(cDv)

		//┌───────────────────────┐
		//│       Sicredi         │
		//└───────────────────────┘

	Case aDadosBanco[01] == "748"
		cRet := SubStr(Trim(cBoleto), 01, 02)  + "/" + SubStr(Trim(cBoleto), 03, 01)  + SubStr(Trim(cBoleto), 04, 05)  + "-" + Trim(cDv)

		//┌────────┐
		//│Sicoob│
		//└────────┘

	Case aDadosBanco[01] == "756"
		cRet := Trim(cBoleto) + "-" + Trim(cDv)

	EndCase

Return cRet

//┌────────────────────────────────────────────8┐
//│FunńŃo que vai gerar a base do nosso n·mero.│
//└────────────────────────────────────────────8┘

Static Function fGerNNro(cSequencia)
	Local cRet   := ""

	Do Case

		//┌───────────────┐
		//│Banco do Brasil│
		//└───────────────┘

	Case aDadosBanco[01] == "001"
		cRet := aDadosBanco[09] + cSequencia

		//┌─────┐
		//│Caixa│
		//└─────┘

	Case aDadosBanco[01] == "104"

		If aDadosBanco[01] == "104" .and. Len(aDadosBanco[09]) != 12
			cRet := "1" + "4" + "000" + cSequencia
		Else
			cRet := "9" + SubStr(cSequencia, 04,10)
		EndIf

		//┌─────────┐
		//│BIC Banco│
		//└─────────┘

	Case aDadosBanco[01] == "320"
		cRet := cSequencia

		//┌───────────┐
		//│Banco Safra│
		//└───────────┘

	Case aDadosBanco[01] == "422"
		cRet := cSequencia

		//┌───────────┐
		//│Banco ID
		//└───────────┘

	Case aDadosBanco[01] == "439"
		cRet := cSequencia

		//┌────────────────t
		//│Banco Votorantim│
		//└────────────────t

	Case aDadosBanco[01] == "655"
		cRet :=  cSequencia

		//┌────────────────t
		//│     Sicredi    │
		//└────────────────t

	Case aDadosBanco[01] == "748"
		cRet := right(alltrim(str(year(dDatabase))),2) + "2" + cSequencia

	OtherWise
		cRet := cSequencia
	EndCase

Return cRet

//┌──────────────────────────────────────────────Õ┐
//│FunńŃo que retorna o dĒgito do c¾digo do banco│
//└──────────────────────────────────────────────Õ┘

Static Function fDvBco(cBanco)
	Local cRet := ""

	Do Case

		//┌─────────────────┐
		//│Banco do Nordeste│
		//└─────────────────┘

	Case cBanco == "004"
		cRet := "-3"

		//┌───────────────
		//│Banco do Brasil│
		//└───────────────

	Case cBanco == "001"
		cRet := "-9"

		//┌─────────┐
		//│Santander│
		//└─────────┘

	Case cBanco == "033"
		cRet := "-7"

		//┌───────────────────────┐
		//│Caixa Econ¶mica Federal│
		//└───────────────────────┘

	Case cBanco == "104"
		cRet := "-0"

		//┌────────┐
		//│Cresol│
		//└────────┘

	Case cBanco == "133"
		cRet := "-3"

		//┌───────────┐
		//│Banco Fibra│
		//└───────────┘

	Case cBanco == "224"
		cRet := "-7"

		//┌────────┐
		//│Bradesco│
		//└────────┘

	Case cBanco == "237"
		cRet := "-2"

		//┌────────┐
		//│UNAVANTI│
		//└────────┘

	Case cBanco == "460"
		cRet := "-X"

		//┌─────────┐
		//│Banco ABC│
		//└─────────┘

	Case cBanco == "246"
		cRet := "-1"

		//┌─────────┐
		//│Bic Banco│
		//└─────────┘

	Case cBanco == "320"
		cRet := "-2"

		//┌────┐
		//│Ita·│
		//└────┘

	Case cBanco == "341"
		cRet := "-7"

		//┌────┐
		//│HSBC│
		//└────┘

	Case cBanco == "399"
		cRet := "-9"

		//┌───────────┐
		//│Banco Safra│
		//└───────────┘

	Case cBanco == "422"
		cRet := "-7"

		//┌────────┐
		//Banco ID
		//└────────┘

	Case cBanco == "439"
		cRet := "-X"
		//┌─────────┐
		//│Banco Luso│
		//└─────────┘

	Case cBanco == "600"
		cRet := "-2"
		//┌──────────────────┐
		//│Banco Panamericano│
		//└──────────────────┘

	Case cBanco == "623"
		cRet := "-2"

		//┌────────────────
		//│Banco Votorantim│
		//└────────────────

	Case cBanco == "655"
		cRet := "-6"

		//┌────────┐
		//│Daycoval│
		//└────────┘

	Case cBanco == "707"
		cRet := "-7"

