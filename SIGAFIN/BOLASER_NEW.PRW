Static Function fDadosBanco(aDadosBanco)

	Local cRet := ""
	Local nX   := 0

	Do Case

		//┌───────────────────────────────────────┐
		//│Caixa, quando cobranńa for layout SIGCB│
		//└───────────────────────────────────────┘

	Case aDadosBanco[01] == '104' .and. Len(aDadosBanco[09]) != 12
		nPeso   := 2
		nSoma   := 0
		nResult := 0
		nResto  := 0

		For nX := Len(aDadosBanco[09]) to 1 step -1
			nSoma += Val(SubStr(aDadosBanco[09], nX, 1)) * nPeso
			nPeso++
		Next nX

		if nSoma < 11
			nResult := 11 - nSoma
		Else
			nResto  := nSoma % 11
			nResult := 11 - nResto
		EndIf

		if nResult > 9
			nResult := 0
		EndIf

		cRet := aDadosBanco[09] + AllTrim(Str(nResult))

	OtherWise
		cRet := aDadosBanco[09]

	EndCase

Return cRet

