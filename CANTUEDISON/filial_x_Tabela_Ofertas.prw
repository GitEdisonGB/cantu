#INCLUDE "parmtype.ch""
#INCLUDE "rwmake.ch"
#INCLUDE "topconn.ch"
#INCLUDE "protheus.ch"   


user function FILTABOF()

Private cCadastro := "Filial x Tabela x Ofertas" //Variavel padrуo para o tэtulo do mBrowse
Private aRotina	:= MENUDEF() //Variсvel padrуo para as opчєes do mBrowse
    
//┌────────────────────────────────────────────────────
//│Chama funчуo para monitor uso de fontes customizados│
//└────────────────────────────────────────────────────
U_USORWMAKE(ProcName(),FunName())

dbSelectArea("ZTO")
ZTO->(dbsetOrder(1))  // FILIAL + COD TABELA
ZTO->(dbGoTop())

//Os parametros sуo padrєes do tamanho da tela que abriu
mBrowse(6,1,22,75,"ZTO") 

Return   

/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
