User Function REPMOTDV()
	Local aArea    := GetArea()
	Local lRet := .T.
	Local nPosMotDev := aScan(aHeader, {|x| AllTrim(x[2]) == "D1_MOTDEV"}) // para obter qual a posi鈬o do campo no acols do codigo da TES.

	If Len( aCols ) > 1 .And. MsgYesNo("Deseja aplicar o mesmo motivo de devolu鈬o para todas as linhas de produtos? ")

		For nAuxCNT := 1 To Len( aCols )
			If (nAuxCNT # n) .And. !aCols[nAuxCNT,Len(aHeader)+1]
				aCols[nAuxCNT,nPosMotDev] := M->D1_MOTDEV
			EndIf
		Next

	EndIf

	RestArea(aArea)

Return lRet
