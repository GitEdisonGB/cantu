User Function ExpCigna()

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Declaracao de Variaveis                                             ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
Private _cString := "SRA"
Private _cPerg   := "EXPCIG"
Private _oGeraTxt

Pergunte(_cPerg,.F.)

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Montagem da tela de processamento.                                  ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

@ 200,1 TO 380,450 DIALOG _oGeraTxt TITLE OemToAnsi("Geracao de Arquivo Exportacao Cigna")
@ 02,10 TO 060,215
@ 10,018 Say " Este programa ira gerar um arquivo texto, conforme os parametros definidos "    SIZE 196,0
@ 18,018 Say " pelo usuario, com  os  registros  do  arquivo temporario,  criado  com  regis-" SIZE 196,0
@ 26,018 Say " tros do arquivo SRA."                                                           SIZE 196,0

@ 70,128 BMPBUTTON TYPE 05 ACTION Pergunte(_cPerg,.T.)
@ 70,158 BMPBUTTON TYPE 01 ACTION OkGeraTrb(_oGeraTxt )
@ 70,188 BMPBUTTON TYPE 02 ACTION Close(_oGeraTxt)

Activate Dialog _oGeraTxt Centered

Return

/*/
ﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ｱｱﾉﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾋﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾋﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｻｱｱ
ｱｱｺFun℡o    ｳ OKGERATRBｺ Autor ｳ AP5 IDE            ｺ Data ｳ  26/06/00   ｺｱｱ
ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺDescri℡o ｳ Funcao chamada pelo botao OK na tela inicial de processamenｺｱｱ
ｱｱｺ          ｳ to. Executa a geracao do arquivo texto.                    ｺｱｱ
ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺUso       ｳ Programa principal                                         ｺｱｱ
ｱｱﾈﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｼｱｱ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟ
/*/

Static Function OkGeraTrb(_oGeraTxt )

Local 	_cEFilMat := ""
Local   _cChave	  := ""
Local   _cCc	  := ""
Local	_aRecTrf  := {}
Local 	_cFilialD := ""
Local	_cMatD	  := ""
Local	_cInicio  := ""
Local   _cFim	  := ""
Local   _cAlias   := ""

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Variaveis utilizadas na pergunte                                 ｳ
//ｳ mv_par01	// Filial de                                         ｳ
//ｳ mv_par02	// Filial ate                                        ｳ
//ｳ mv_par03	// Data de referencia                                ｳ
//ｳ mv_par04	// Tipo de geracao(Carga Inicial¥Atualizacao)        ｳ
//ｳ mv_par05	// Path destino geracao                              ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
Local _cFilDe := mv_par01
Local _cFilAte:= mv_par02
Local _dDatRef:= mv_par03
Local _nTipGer:= mv_par04
Local _cPath  := Substr(mv_par05,1,Rat("¥",mv_par05))
Local _byOrd  := 0

Private _cFile   := _cPath+"FURM"+Soma1(GetMV("MV_NUMFURM"),4)
Private _cFileDbf := RetArq(__LocalDriver,(_cFile+GetDBExtension()),.T.)

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Cria o arquivo texto                                                ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
Private _nHdl    := fCreate(_cFile+".TXT")

Private _cEOL    := "CHR(13)+CHR(10)"
If Empty(_cEOL)
	_cEOL := CHR(13)+CHR(10)
Else
	_cEOL := Trim(_cEOL)
	_cEOL := &_cEOL
Endif

If _nHdl == -1
	MsgAlert("O arquivo "+_cFile+".TXT"+" nao pode ser executado! Verifique os parametros.","Atencao!")
	Return
Else
	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳ Grava a Numero da sequencia do arquivo texto.                ｳ
	//ｳ Utilize sempre GetMv para posicionar o SX6. N⏌ use SEEK !!! ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	_cAlias := Alias()
	_byOrd	:= IndexOrd()
	dbSelectArea("SX6")
	GetMV("MV_NUMFURM")
	RecLock("SX6",.F.)
	PutMV(FieldGet(FieldPos("X6_VAR"), Soma1(GetMV("MV_NUMFURM"),4)))
	MSUnlock()
	dbSelectArea(_cAlias)
	If _byOrd>0
		dbSetOrder(_byOrd)
	Endif
Endif

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Cria o arquivo dbf                                                  ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
Cria_TRB()

dbSelectArea("SRA")
dbSetOrder(1)
dbGoTop()
dbSeek(_cFilDe , .T.)
_cInicio := "SRA->RA_FILIAL"
_cFim    := _cFilAte

While !Eof() .And. &_cInicio <= _cFim
	If (SRA->RA_SITFOLH == "D" .And. SRA->RA_RESCRAI == "31") .Or.;
		(SRA->RA_SITFOLH == "D" .And. Mesano(SRA->RA_DEMISSA) < MesAno(CtoD("01"+"/"+StrZero(Month(_dDatRef)-1,2)+"/"+Str(Year(_dDatRef),4))))
		dbSkip()
		Loop
	Endif
	dbSelectArea("TRB")
	RecLock("TRB",.T.)
	If SRA->RA_SITFOLH == "D" .And. SRA->RA_RESCRAI # "31"
		Replace TRB->TIPODADO 	With  "DM"
	ElseIf SRA->RA_SITFOLH == "F"
		Replace TRB->TIPODADO 	With  "FE"
	Else
		Replace TRB->TIPODADO 	With  "FU"
	EndIf
	If _nTipGer # 1 .And. MesAno(SRA->RA_ADMISSA) >= MesAno(CtoD("01"+"/"+StrZero(Month(_dDatRef)-1,2)+"/"+Str(Year(_dDatRef),4)))
		Replace TRB->CODACAO  With  "UP"
	Else
		Replace TRB->CODACAO  With  "NW"
	EndIf
	Replace TRB->FILIAL		With  SRA->RA_FILIAL
	Replace TRB->MAT		With  SRA->RA_MAT
	Replace TRB->NOME		With  SRA->RA_NOME
	Replace TRB->CC			With  SRA->RA_CC
	Replace TRB->CODFUNC	With  SRA->RA_CODFUNC
	Replace TRB->SEXO		With  SRA->RA_SEXO
	Replace TRB->NASC		With  SRA->RA_NASC
	Replace TRB->CIC		With  SRA->RA_CIC
	Replace TRB->ADMISSA	With  SRA->RA_ADMISSA
	Replace TRB->ESTCIVI	With  SRA->RA_ESTCIVI
	Replace TRB->ENDEREC	With  SRA->RA_ENDEREC
	Replace TRB->COMPLEM	With  SRA->RA_COMPLEM
	Replace TRB->BAIRRO		With  SRA->RA_BAIRRO
	Replace TRB->MUNICIP	With  SRA->RA_MUNICIP
	Replace TRB->CEP		With  SRA->RA_CEP
	Replace TRB->UFCP  	    With  SRA->RA_UFCP
	Replace TRB->TELEFON	With  SRA->RA_TELEFON
	Replace TRB->EMAIL		With  SRA->RA_EMAIL
	If SRA->RA_SITFOLH == "D" .And. SRA->RA_RESCRAI # "31"
		Replace TRB->DEMISSA	With  SRA->RA_DEMISSA
		Replace TRB->AFASFGT	With  SRA->RA_AFASFGT

	ElseIf SRA->RA_SITFOLH == "F"
		dbSelectArea("SRH")
		dbSetOrder(1)
		If dbSeek(SRA->RA_FILIAL+SRA->RA_MAT)
			Replace TRB->DATAINI	With  SRH->RH_DATAINI
			Replace TRB->DATAFIM	With  SRH->RH_DATAFIM
		EndIf
	EndIf
	dbSelectArea("TRB")
	If _nTipGer # 1
		_cChave := SRA->RA_FILIAL+SRA->RA_MAT
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳ Seleciona o Arquivo de Transferencias                        ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		dbSelectArea("SRE")
		dbSetOrder(2)
		If dbSeek(cEmpAnt+_cChave)
			_cEFilMat := cEmpAnt+_cChave
			_cCc      := SRA->RA_CC
			While ! EOF() .And. SRE->RE_EMPP+SRE->RE_FILIALP+SRE->RE_MATP == _cEFilMat
				If SRE->RE_CCP == _cCc
					If Ascan(_aRecTrf,SRE->(RECNO())) > 0
						dbSkip()
						Loop
					Else
						Aadd(_aRecTrf,SRE->(RECNO()))
					Endif
				EndIf
				If(SRE->RE_EMPP+SRE->RE_FILIALP+SRE->RE_MATP+SRE->RE_CCP==_cEFilMat+_cCc)
					_cEFilMat := SRE->RE_EMPD + SRE->RE_FILIALD + SRE->RE_MATD
					_cCc      := SRE->RE_CCD
					If SRE->RE_EMPP + SRE->RE_FILIALP + SRE->RE_MATP # _cEFilMat
						If MesAno(SRE->RE_DATA) >= MesAno(CtoD("01"+"/"+StrZero(Month(_dDatRef)-1,2)+"/"+Str(Year(_dDatRef),4)))
							If SRE->RE_EMPD == SRE->RE_EMPP
								_cFilialD := SRE->RE_FILIALD
								_cMatD	  := SRE->RE_MATD
							EndIf
						EndIf
					EndIf
					dbSeek(_cEFilMat)
				Else
					dbSkip()
				EndIf
			EndDo
			If _cFilialD+_cMatD # "" .And. _cFilialD+_cMatD # SRA->RA_FILIAL+SRA->RA_MAT
				dbSelectArea("TRB")
				RecLock("TRB",.T.)
				Replace TRB->TIPODADO	With  "TR"
				Replace TRB->CODACAO	With  "NW"
				Replace TRB->FILIAL		With  SRA->RA_FILIAL
				Replace TRB->MAT		With  SRA->RA_MAT
				Replace TRB->CC			With  SRA->RA_CC
				Replace	TRB->CODFUNC	With  SRA->RA_CODFUNC
				Replace TRB->FILIALD	With  _cFilialD
				Replace TRB->MATD		With  _cMatD
				MsUnlock()
			EndIf
		EndIf
	EndIf
	dbSelectArea("SRA")
	dbSkip()
EndDo

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Inicializa a regua de processamento                                 ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

Processa({|| RunCont(_dDatRef) },"Processando...")
Close(_oGeraTxt)
Return

/*/
ﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ｱｱﾉﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾋﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾋﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｻｱｱ
ｱｱｺFun℡o    ｳ RUNCONT  ｺ Autor ｳ AP5 IDE            ｺ Data ｳ  26/06/00   ｺｱｱ
ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺDescri℡o ｳ Funcao auxiliar chamada pela PROCESSA.  A funcao PROCESSA  ｺｱｱ
ｱｱｺ          ｳ monta a janela com a regua de processamento.               ｺｱｱ
ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺUso       ｳ Programa principal                                         ｺｱｱ
ｱｱﾈﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｼｱｱ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟ
/*/

Static Function RunCont(_dDatRef)

Local _nTamLin, _cLin, _cCpo
Local _cRazao := ""
Local _cFilialAnt := "!!"
Local _aInfo := {}

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Posicionamento do primeiro registro e loop principal. Pode-se criar ｳ
//ｳ a logica da seguinte maneira: Posiciona-se na filial corrente e pro ｳ
//ｳ cessa enquanto a filial do registro for a filial corrente. Por exem ｳ
//ｳ plo, substitua o dbGoTop() e o While !EOF() abaixo pela sintaxe:    ｳ
//ｳ                                                                     ｳ
//ｳ dbSeek(xFilial())                                                   ｳ
//ｳ While !EOF() .And. xFilial() == A1_FILIAL                           ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ O tratamento dos parametros deve ser feito dentro da logica do seu  ｳ
//ｳ programa.  Geralmente a chave principal e a filial (isto vale prin- ｳ
//ｳ cipalmente se o arquivo for um arquivo padrao). Posiciona-se o pri- ｳ
//ｳ meiro registro pela filial + pela chave secundaria (codigo por exem ｳ
//ｳ plo), e processa enquanto estes valores estiverem dentro dos parame ｳ
//ｳ tros definidos. Suponha por exemplo o uso de dois parametros:       ｳ
//ｳ mv_par01 -> Indica o codigo inicial a processar                     ｳ
//ｳ mv_par02 -> Indica o codigo final a processar                       ｳ
//ｳ                                                                     ｳ
//ｳ dbSeek(xFilial()+mv_par01,.T.) // Posiciona no 1o.reg. satisfatorio ｳ
//ｳ While !EOF() .And. xFilial() == A1_FILIAL .And. A1_COD <= mv_par02  ｳ
//ｳ                                                                     ｳ
//ｳ Assim o processamento ocorrera enquanto o codigo do registro posicioｳ
//ｳ nado for menor ou igual ao parametro mv_par02, que indica o codigo  ｳ
//ｳ limite para o processamento. Caso existam outros parametros a serem ｳ
//ｳ checados, isto deve ser feito dentro da estrutura de la輟 (WHILE):  ｳ
//ｳ                                                                     ｳ
//ｳ mv_par01 -> Indica o codigo inicial a processar                     ｳ
//ｳ mv_par02 -> Indica o codigo final a processar                       ｳ
//ｳ mv_par03 -> Considera qual estado?                                  ｳ
//ｳ                                                                     ｳ
//ｳ dbSeek(xFilial()+mv_par01,.T.) // Posiciona no 1o.reg. satisfatorio ｳ
//ｳ While !EOF() .And. xFilial() == A1_FILIAL .And. A1_COD <= mv_par02  ｳ
//ｳ                                                                     ｳ
//ｳ     If A1_EST <> mv_par03                                           ｳ
//ｳ         dbSkip()                                                    ｳ
//ｳ         Loop                                                        ｳ
//ｳ     Endif                                                           ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

dbSelectArea("TRB")
dbGoTop()

ProcRegua(RecCount()) // Numero de registros a processar

_nTamLin := 23
_cLin    := Space(_nTamLin)+_cEOL // Variavel para criacao da linha do registros para gravacao

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Substitui nas respectivas posicioes na variavel cLin pelo conteudo  ｳ
//ｳ dos campos segundo o Lay-Out. Utiliza a funcao STUFF insere uma     ｳ
//ｳ string dentro de outra string.                                      ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
_cCpo := "H"+"00"+"      "+"LEN"+Transforma(_dDatRef)+"POS"
_cLin := Stuff(_cLin,01,23,_cCpo)

If fWrite(_nHdl,_cLin,Len(_cLin)) != Len(_cLin)
	If !MsgAlert("Ocorreu um erro na gravacao do arquivo. Continua?","Atencao!")
		Return
	Endif
Endif

While !EOF()

	If TRB->FILIAL # _cFilialAnt
		If !fInfo(@_aInfo,TRB->FILIAL)
			Exit
		Endif
		dbSelectArea( "TRB" )
		_cFilialAnt := TRB->FILIAL
	Endif

	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳ Incrementa a regua                                                  ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ

	IncProc()

	//ﾉﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｻ
	//ｺ Lay-Out do arquivo Texto gerado:                                ｺ
	//ﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹ
	//ｺCampo           ｳ Inicio ｳ Tamanho                               ｺ
